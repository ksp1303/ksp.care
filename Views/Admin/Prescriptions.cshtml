@model ksp.care.Helpers.PaginatedList<ksp.care.Models.PrescriptionRecord>
@{
    ViewData["Title"] = "Prescriptions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var doctors = ViewBag.Doctors as List<ksp.care.Models.DoctorRecord> ?? new List<ksp.care.Models.DoctorRecord>();
    var appointments = ViewBag.Appointments as List<ksp.care.Models.AppointmentRecord> ?? new List<ksp.care.Models.AppointmentRecord>();
}

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<div class="grid lg:grid-cols-3 gap-8">
    <!-- Add Prescription Form -->
    <div class="glass-panel rounded-[24px] border border-white/10 p-8 h-fit">
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="bi bi-file-earmark-medical text-teal-400"></i> New Prescription
        </h2>
        <form asp-action="AddPrescription" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Select Patient</label>
                <select name="patientMobile" required class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50">
                    <option value="" class="bg-black">Choose Patient</option>
                    @if (ViewBag.Patients != null) {
                        foreach (var p in ViewBag.Patients) {
                            <option value="@p.Mobile" class="bg-black">@p.FirstName @p.LastName (@p.Mobile)</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Doctor</label>
                <select name="doctorName" required class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50">
                    <option value="" class="bg-black">Select Doctor</option>
                    @foreach (var doc in doctors) {
                        <option value="@doc.Name" class="bg-black">@doc.Name — @doc.Specialization</option>
                    }
                </select>
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Appointment (Optional)</label>
                <select name="appointmentId" class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50">
                    <option value="" class="bg-black">No linked appointment</option>
                    @foreach (var apt in appointments) {
                        <option value="@apt.Id" class="bg-black">#@apt.Id — @apt.PatientName (@apt.PackageName)</option>
                    }
                </select>
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Diagnosis</label>
                <input type="text" name="diagnosis"
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50 placeholder:text-white/30"
                    placeholder="Diagnosis" />
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Medicines *</label>
                <textarea name="medicines" required rows="4"
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50 placeholder:text-white/30 resize-none"
                    placeholder="List medicines, dosage, and frequency..."></textarea>
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Notes</label>
                <textarea name="notes" rows="2"
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-teal-500/50 placeholder:text-white/30 resize-none"
                    placeholder="Additional notes..."></textarea>
            </div>
            <button type="submit"
                class="w-full px-6 py-3 bg-teal-600 hover:bg-teal-500 text-white font-bold text-sm rounded-xl transition-colors">
                <i class="bi bi-plus-lg mr-2"></i> Add Prescription
            </button>
        </form>
    </div>

    <!-- Prescriptions List -->
    <div class="lg:col-span-2 glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
        <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
            <h2 class="text-xl font-bold text-white m-0">All Prescriptions</h2>
            <form method="get" class="flex items-center gap-2">
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Search patient or doctor..."
                    class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-teal-500/50 placeholder:text-white/30 w-56" />
                <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                    <a href="/Admin/Prescriptions" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm rounded-lg transition-colors no-underline">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </form>
        </div>

        @if (!Model.Any()) {
            <div class="p-16 text-center">
                <i class="bi bi-file-earmark-medical text-5xl text-white/20 block mb-3"></i>
                <p class="text-white/40 font-medium">No prescriptions found.</p>
            </div>
        } else {
            <div class="divide-y divide-white/5">
                @foreach (var rx in Model) {
                    <div class="p-6 hover:bg-white/[0.02] transition-colors">
                        <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                            <div>
                                <div class="text-white font-bold text-sm">@rx.PatientName</div>
                                <div class="text-white/40 text-xs font-mono">@rx.PatientMobile</div>
                            </div>
                            <div class="text-right">
                                <div class="text-teal-400 text-sm font-semibold">@rx.DoctorName</div>
                                <div class="text-white/30 text-xs">@rx.CreatedAt.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(rx.Diagnosis)) {
                            <div class="mb-2">
                                <span class="text-white/40 text-xs font-bold uppercase">Diagnosis:</span>
                                <span class="text-white/80 text-sm ml-2">@rx.Diagnosis</span>
                            </div>
                        }
                        <div class="mb-2">
                            <span class="text-white/40 text-xs font-bold uppercase">Medicines:</span>
                            <p class="text-white/80 text-sm mt-1 whitespace-pre-line">@rx.Medicines</p>
                        </div>
                        @if (!string.IsNullOrEmpty(rx.Notes)) {
                            <div class="mt-2 p-3 bg-white/5 rounded-lg">
                                <span class="text-white/40 text-xs font-bold uppercase">Notes:</span>
                                <p class="text-white/60 text-sm mt-1">@rx.Notes</p>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (Model.TotalPages > 1) {
            <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
                @if (Model.HasPreviousPage) {
                    <a href="/Admin/Prescriptions?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                       class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                }
                <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
                @if (Model.HasNextPage) {
                    <a href="/Admin/Prescriptions?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                       class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        }
    </div>
</div>
