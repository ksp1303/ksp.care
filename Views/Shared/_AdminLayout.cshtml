<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@ViewData["Title"] — KSPcare Admin</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tailwind.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body { font-family: 'General Sans', sans-serif; background-color: #050505; color: white; min-height: 100vh; overflow-x: hidden; }
        .glass-panel { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(12px); }
        .custom-select { background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px; padding: 6px 12px; outline: none; font-size: 13px; }
        .custom-select option { background-color: #111; color: #fff; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #2a2a2a; border-radius: 4px; }

        /* Admin mobile menu */
        .admin-mobile-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.6);
            z-index: 199; opacity: 0; visibility: hidden; transition: all 0.3s;
        }
        .admin-mobile-overlay.open { opacity: 1; visibility: visible; }
        .admin-mobile-menu {
            position: fixed; top: 0; right: -100%; width: 280px; height: 100vh;
            background: #0a0a0e; border-left: 1px solid rgba(255,255,255,0.06);
            z-index: 200; transition: right 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            padding: 80px 24px 32px; overflow-y: auto;
        }
        .admin-mobile-menu.open { right: 0; }
        .admin-mobile-link {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px; border-radius: 12px;
            font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.6);
            text-decoration: none; transition: all 0.15s;
        }
        .admin-mobile-link:hover { background: rgba(255,255,255,0.05); color: white; }
        .admin-mobile-link.active { color: white; background: rgba(59,130,246,0.1); }
        .admin-mobile-section { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.25); padding: 16px 16px 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #444; }

        /* Dropdown nav */
        .nav-dropdown { position: relative; }
        .nav-dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            min-width: 200px;
            background: #111;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            padding: 8px;
            padding-top: 14px;
            z-index: 100;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }
        /* Invisible bridge — closes the gap between trigger and menu so hover doesn't break */
        .nav-dropdown-menu::before {
            content: '';
            position: absolute;
            top: -10px;
            left: 0;
            right: 0;
            height: 14px;
            background: transparent;
        }
        .nav-dropdown:hover .nav-dropdown-menu,
        .nav-dropdown.open .nav-dropdown-menu { display: block; }
        .nav-dropdown-menu a {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 14px; border-radius: 10px;
            font-size: 13px; font-weight: 600;
            color: rgba(255,255,255,0.7); text-decoration: none;
            transition: all 0.15s;
        }
        .nav-dropdown-menu a:hover { background: rgba(255,255,255,0.07); color: white; }
        .nav-dropdown-menu a.active { color: white; background: rgba(59,130,246,0.15); }
        .nav-drop-trigger {
            display: flex; align-items: center; gap: 4px;
            font-size: 13px; font-weight: 700;
            padding: 6px 10px; border-radius: 8px;
            cursor: pointer; transition: all 0.15s;
            white-space: nowrap;
        }
        .nav-drop-trigger:hover { background: rgba(255,255,255,0.07); color: white; }
        .nav-drop-trigger.active-group { color: white; }
    </style>
</head>
<body class="bg-[#050505]">

    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
        bool isPatientGroup   = new[]{"Patient","RegisterPatient","EditPatient"}.Contains(currentAction);
        bool isBillingGroup   = new[]{"PendingBill","BillEdit","FinancialReport"}.Contains(currentAction);
        bool isTestGroup      = new[]{"Tests","PendingTests","Report"}.Contains(currentAction);
        bool isOtherGroup     = new[]{"Prescriptions","Analytics","Doctors","ContactMessages"}.Contains(currentAction);
    }

    <nav class="w-full flex items-center justify-between px-5 py-3 border-b border-white/10 bg-black/90 backdrop-blur-md sticky top-0 z-50">
        <!-- Logo -->
        <a href="/Admin/Dashboard" class="flex items-center gap-2.5 no-underline shrink-0">
            <i class="bi bi-heptagon-half text-blue-500 text-2xl"></i>
            <div class="leading-tight">
                <div class="text-lg font-bold text-white lowercase">ksp<span class="text-blue-500">care</span></div>
                <div class="text-white/40 text-[9px] tracking-[0.2em] uppercase font-bold">Admin Portal</div>
            </div>
        </a>

        <!-- Nav Links -->
        <div class="hidden md:flex items-center gap-1">
            <!-- Dashboard -->
            <a asp-controller="Admin" asp-action="Dashboard"
               class="nav-drop-trigger no-underline @(currentAction == "Dashboard" ? "text-white active-group" : "text-white/50")">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>

            <!-- Patients Dropdown -->
            <div class="nav-dropdown">
                <div class="nav-drop-trigger @(isPatientGroup ? "text-white active-group" : "text-white/50")">
                    <i class="bi bi-people"></i> Patients <i class="bi bi-chevron-down text-[9px]"></i>
                </div>
                <div class="nav-dropdown-menu">
                    <a href="/Admin/Patient" class="@(currentAction == "Patient" ? "active" : "")">
                        <i class="bi bi-list-ul"></i> All Patients
                    </a>
                    <a href="/Admin/RegisterPatient" class="@(currentAction == "RegisterPatient" ? "active" : "")">
                        <i class="bi bi-person-plus"></i> Register Patient
                    </a>
                </div>
            </div>

            <!-- Tests Dropdown -->
            <div class="nav-dropdown">
                <div class="nav-drop-trigger @(isTestGroup ? "text-white active-group" : "text-white/50")">
                    <i class="bi bi-flask"></i> Tests <i class="bi bi-chevron-down text-[9px]"></i>
                </div>
                <div class="nav-dropdown-menu">
                    <a href="/Admin/Tests" class="@(currentAction == "Tests" ? "active" : "")">
                        <i class="bi bi-journal-medical"></i> Test Catalog
                    </a>
                    <a href="/Admin/PendingTests" class="@(currentAction == "PendingTests" ? "active" : "")">
                        <i class="bi bi-hourglass-split"></i> Pending Tests
                    </a>
                    <a href="/Admin/Report" class="@(currentAction == "Report" ? "active" : "")">
                        <i class="bi bi-upload"></i> Upload Report
                    </a>
                </div>
            </div>

            <!-- Billing Dropdown -->
            <div class="nav-dropdown">
                <div class="nav-drop-trigger @(isBillingGroup ? "text-white active-group" : "text-white/50")">
                    <i class="bi bi-receipt"></i> Billing <i class="bi bi-chevron-down text-[9px]"></i>
                </div>
                <div class="nav-dropdown-menu">
                    <a href="/Admin/PendingBill" class="@(currentAction == "PendingBill" ? "active" : "")">
                        <i class="bi bi-clock-history"></i> Pending Bills
                    </a>
                    <a href="/Admin/BillEdit" class="@(currentAction == "BillEdit" ? "active" : "")">
                        <i class="bi bi-pencil-square"></i> Manage Bills
                    </a>
                    <a href="/Admin/FinancialReport" class="@(currentAction == "FinancialReport" ? "active" : "")">
                        <i class="bi bi-bar-chart-line"></i> Financial Report
                    </a>
                </div>
            </div>

            <!-- More Dropdown -->
            <div class="nav-dropdown">
                <div class="nav-drop-trigger @(isOtherGroup ? "text-white active-group" : "text-white/50")">
                    <i class="bi bi-three-dots"></i> More <i class="bi bi-chevron-down text-[9px]"></i>
                </div>
                <div class="nav-dropdown-menu">
                    <a href="/Admin/Doctors" class="@(currentAction == "Doctors" ? "active" : "")">
                        <i class="bi bi-heart-pulse"></i> Doctors
                    </a>
                    <a href="/Admin/Prescriptions" class="@(currentAction == "Prescriptions" ? "active" : "")">
                        <i class="bi bi-file-medical"></i> Prescriptions
                    </a>
                    <a href="/Admin/Analytics" class="@(currentAction == "Analytics" ? "active" : "")">
                        <i class="bi bi-graph-up-arrow"></i> Analytics
                    </a>
                    <a href="/Admin/ContactMessages" class="@(currentAction == "ContactMessages" ? "active" : "")">
                        <i class="bi bi-envelope"></i> Messages
                    </a>
                </div>
            </div>
        </div>

        <!-- Staff Info + Logout -->
        <div class="flex items-center gap-3 border-l border-white/10 pl-4 ml-2">
            <div class="w-9 h-9 rounded-full bg-blue-500/20 border border-blue-500/30 flex items-center justify-center">
                <i class="bi bi-person-badge text-blue-400 text-base"></i>
            </div>
            <div class="hidden md:block leading-tight">
                <div class="text-[13px] font-bold text-white">@Context.Session.GetString("CurrentStaffId")</div>
                <div class="text-[10px] text-white/40">Lab Staff</div>
            </div>
            <a asp-controller="Admin" asp-action="Logout"
               class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white/40 hover:text-red-400 hover:bg-red-500/10 transition-colors ml-1 no-underline hidden md:flex" title="Logout">
                <i class="bi bi-box-arrow-right text-sm"></i>
            </a>
            <!-- Mobile hamburger -->
            <button id="adminMobileBtn" class="md:hidden w-10 h-10 flex items-center justify-center text-white/60 hover:text-white transition-colors" aria-label="Open menu">
                <i class="bi bi-list text-2xl"></i>
            </button>
        </div>
    </nav>

    <!-- Admin Mobile Menu -->
    <div class="admin-mobile-overlay" id="adminMobileOverlay"></div>
    <div class="admin-mobile-menu" id="adminMobileMenu">
        <button id="adminMobileClose" class="absolute top-6 right-6 text-white/50 hover:text-white text-2xl transition-colors" aria-label="Close menu">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="flex flex-col gap-1">
            <a href="/Admin/Dashboard" class="admin-mobile-link @(currentAction == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2 text-lg"></i> Dashboard
            </a>
            <div class="admin-mobile-section">Patients</div>
            <a href="/Admin/Patient" class="admin-mobile-link @(currentAction == "Patient" ? "active" : "")">
                <i class="bi bi-list-ul text-lg"></i> All Patients
            </a>
            <a href="/Admin/RegisterPatient" class="admin-mobile-link @(currentAction == "RegisterPatient" ? "active" : "")">
                <i class="bi bi-person-plus text-lg"></i> Register Patient
            </a>
            <div class="admin-mobile-section">Tests & Reports</div>
            <a href="/Admin/Tests" class="admin-mobile-link @(currentAction == "Tests" ? "active" : "")">
                <i class="bi bi-journal-medical text-lg"></i> Test Catalog
            </a>
            <a href="/Admin/PendingTests" class="admin-mobile-link @(currentAction == "PendingTests" ? "active" : "")">
                <i class="bi bi-hourglass-split text-lg"></i> Pending Tests
            </a>
            <a href="/Admin/Report" class="admin-mobile-link @(currentAction == "Report" ? "active" : "")">
                <i class="bi bi-upload text-lg"></i> Upload Report
            </a>
            <div class="admin-mobile-section">Billing</div>
            <a href="/Admin/PendingBill" class="admin-mobile-link @(currentAction == "PendingBill" ? "active" : "")">
                <i class="bi bi-clock-history text-lg"></i> Pending Bills
            </a>
            <a href="/Admin/BillEdit" class="admin-mobile-link @(currentAction == "BillEdit" ? "active" : "")">
                <i class="bi bi-pencil-square text-lg"></i> Manage Bills
            </a>
            <a href="/Admin/FinancialReport" class="admin-mobile-link @(currentAction == "FinancialReport" ? "active" : "")">
                <i class="bi bi-bar-chart-line text-lg"></i> Financial Report
            </a>
            <div class="admin-mobile-section">More</div>
            <a href="/Admin/Doctors" class="admin-mobile-link @(currentAction == "Doctors" ? "active" : "")">
                <i class="bi bi-heart-pulse text-lg"></i> Doctors
            </a>
            <a href="/Admin/Prescriptions" class="admin-mobile-link @(currentAction == "Prescriptions" ? "active" : "")">
                <i class="bi bi-file-medical text-lg"></i> Prescriptions
            </a>
            <a href="/Admin/Analytics" class="admin-mobile-link @(currentAction == "Analytics" ? "active" : "")">
                <i class="bi bi-graph-up-arrow text-lg"></i> Analytics
            </a>
            <a href="/Admin/ContactMessages" class="admin-mobile-link @(currentAction == "ContactMessages" ? "active" : "")">
                <i class="bi bi-envelope text-lg"></i> Messages
            </a>
            <hr class="border-white/10 my-3" />
            <a asp-controller="Admin" asp-action="Logout" class="admin-mobile-link text-red-400/70 hover:text-red-400">
                <i class="bi bi-box-arrow-right text-lg"></i> Logout
            </a>
        </div>
    </div>

    <main class="container mx-auto px-6 py-8 max-w-[1400px]">
        @RenderBody()
    </main>

    <script src="~/js/site.js"></script>
    <script>
        // Click-toggle for nav dropdowns (touch devices + hover fallback)
        document.querySelectorAll('.nav-dropdown > .nav-drop-trigger').forEach(function(trigger) {
            trigger.addEventListener('click', function(e) {
                e.stopPropagation();
                var parent = this.parentElement;
                var wasOpen = parent.classList.contains('open');
                // Close all dropdowns first
                document.querySelectorAll('.nav-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
                // Toggle the clicked one
                if (!wasOpen) parent.classList.add('open');
            });
        });
        // Close dropdowns when clicking outside
        document.addEventListener('click', function() {
            document.querySelectorAll('.nav-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
        });
        // Prevent menu clicks from closing the dropdown prematurely
        document.querySelectorAll('.nav-dropdown-menu').forEach(function(menu) {
            menu.addEventListener('click', function(e) { e.stopPropagation(); });
        });

        // Admin mobile menu toggle
        (function() {
            var btn = document.getElementById('adminMobileBtn');
            var closeBtn = document.getElementById('adminMobileClose');
            var menu = document.getElementById('adminMobileMenu');
            var overlay = document.getElementById('adminMobileOverlay');
            function openMenu() {
                menu.classList.add('open');
                overlay.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
            function closeMenu() {
                menu.classList.remove('open');
                overlay.classList.remove('open');
                document.body.style.overflow = '';
            }
            if (btn) btn.addEventListener('click', openMenu);
            if (closeBtn) closeBtn.addEventListener('click', closeMenu);
            if (overlay) overlay.addEventListener('click', closeMenu);
        })();
    </script>
</body>
</html>
