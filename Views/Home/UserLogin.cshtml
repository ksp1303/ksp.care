@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Patient Login"; }

<style>
    .login-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #030305;
        overflow: hidden;
    }
    .login-bg-grid {
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml;base64,");
        opacity: 0.5;
    }
    .login-orb-1 {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: rgba(59,130,246,0.06);
        filter: blur(100px);
        top: -10%;
        right: -10%;
        pointer-events: none;
    }
    .login-orb-2 {
        position: absolute;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: rgba(139,92,246,0.04);
        filter: blur(80px);
        bottom: -5%;
        left: -5%;
        pointer-events: none;
    }
    .login-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 440px;
        margin: 0 16px;
        padding: 40px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    }
    .login-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 20%;
        right: 20%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent);
    }
    .auth-input {
        background-color: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.06) !important;
        color: white !important;
        border-radius: 14px !important;
        padding: 14px 16px 14px 46px !important;
        width: 100% !important;
        outline: none !important;
        font-size: 14px;
        transition: all 0.25s ease !important;
    }
    .auth-input:focus {
        border-color: rgba(59,130,246,0.5) !important;
        background-color: rgba(255,255,255,0.06) !important;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.1) !important;
    }
    .auth-input::placeholder { color: rgba(255,255,255,0.25); }
    .input-icon {
        position: absolute;
        left: 16px;
        bottom: 15px;
        color: rgba(255,255,255,0.30);
        font-size: 18px;
        z-index: 10;
        pointer-events: none;
    }
    .auth-btn {
        width: 100%;
        padding: 14px 24px;
        background: #3b82f6;
        color: white;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 14px;
        border: none;
        transition: all 0.25s ease;
        box-shadow: 0 0 20px rgba(59,130,246,0.25);
    }
    .auth-btn:hover {
        background: #2563eb;
        box-shadow: 0 0 30px rgba(59,130,246,0.4);
        transform: translateY(-2px);
    }
</style>

<div class="login-page">
    <div class="login-bg-grid"></div>
    <div class="login-orb-1"></div>
    <div class="login-orb-2"></div>

    <div class="login-card anim-fade-up">
        <!-- Logo -->
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 mb-6 no-underline">
                <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                    <i class="bi bi-droplet-fill text-blue-500 text-xl"></i>
                </div>
                <span class="text-xl font-bold text-white lowercase">ksp<span class="text-blue-500">care</span></span>
            </a>
            <h2 class="text-2xl font-bold text-white mb-2">Patient Portal</h2>
            <p class="text-white/40 text-sm">Enter your credentials to access your dashboard.</p>
        </div>

        @if (TempData["Success"] != null) {
            <div class="mb-6 p-3.5 rounded-xl bg-green-500/10 border border-green-500/20 text-green-400 text-center text-sm font-medium">
                <i class="bi bi-check-circle mr-1"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null) {
            <div class="mb-6 p-3.5 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-center text-sm font-medium">
                <i class="bi bi-exclamation-triangle mr-1"></i> @TempData["Error"]
            </div>
        }

        <form asp-controller="Home" asp-action="ProcessUserLogin" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-5 relative">
                <label class="block text-[11px] font-bold text-white/40 uppercase tracking-wider mb-2">Mobile Number</label>
                <i class="bi bi-phone input-icon"></i>
                <input type="tel" name="identifier" class="auth-input" placeholder="Enter registered mobile" required>
            </div>
            <div class="mb-8 relative">
                <label class="block text-[11px] font-bold text-white/40 uppercase tracking-wider mb-2">Password</label>
                <i class="bi bi-lock input-icon"></i>
                <input type="password" name="password" class="auth-input" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="auth-btn">
                <i class="bi bi-box-arrow-in-right mr-1"></i> Access Portal
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-white/[0.06]">
            <p class="text-white/30 text-sm mb-3">Don't have an account?</p>
            <a href="/#create-profile" class="text-blue-400/70 hover:text-blue-400 text-sm font-medium no-underline transition-colors">Create Health Profile →</a>
        </div>

        <div class="mt-4 text-center">
            <a href="/" class="text-white/25 hover:text-white/50 text-xs no-underline transition-colors">
                <i class="bi bi-arrow-left mr-1"></i> Back to Main Site
            </a>
        </div>
    </div>
</div>