@model ksp.care.Models.PatientRecord 
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    var avatar = ksp.care.Helpers.AvatarHelper.GetAvatar(Model.Gender, Model.Age);
    var initials = "";
    if (!string.IsNullOrEmpty(Model.FirstName)) initials += Model.FirstName[0];
    if (!string.IsNullOrEmpty(Model.LastName)) initials += Model.LastName[0];
    if (string.IsNullOrEmpty(initials)) initials = "?";
    var hasPhoto = !string.IsNullOrEmpty(Model.ProfilePhoto);
}

<div class="max-w-[800px] mx-auto py-10">

    <style>
        @@keyframes ringPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.1); }
            50% { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
        }
        @@keyframes glowPulse {
            0%, 100% { opacity: 0.3; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.08); }
        }
        .avatar-ring { animation: ringPulse 3s ease-in-out infinite; }
        .glow-pulse { animation: glowPulse 3s ease-in-out infinite; }

        .photo-upload-area {
            position: relative;
            cursor: pointer;
        }
        .photo-upload-area:hover .upload-overlay {
            opacity: 1;
        }
        .upload-overlay {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: rgba(0,0,0,0.6);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.25s ease;
            z-index: 10;
        }
    </style>

    <!-- Profile Banner -->
    <div class="mb-10 relative overflow-hidden rounded-[28px] border border-white/10"
         style="background: linear-gradient(135deg, @(avatar.BgColor), rgba(0,0,0,0.3)); min-height: 180px;">

        <!-- Glow -->
        <div class="absolute right-6 sm:right-14 top-1/2 -translate-y-1/2 w-32 h-32 sm:w-44 sm:h-44 rounded-full glow-pulse pointer-events-none"
             style="background: radial-gradient(circle, @(avatar.GlowColor), transparent 70%); z-index: 1;"></div>

        <!-- Avatar with Upload -->
        <div class="absolute right-4 sm:right-10 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2" style="z-index: 5;">
            <div class="photo-upload-area" onclick="document.getElementById('photoInput').click();">
                @if (hasPhoto) {
                    <img src="@Model.ProfilePhoto" alt="@Model.FirstName"
                         class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover shadow-2xl avatar-ring"
                         style="border: 3px solid rgba(255,255,255,0.25);" />
                } else {
                    <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full flex items-center justify-center text-white font-bold text-3xl sm:text-4xl shadow-2xl avatar-ring"
                         style="background: @(avatar.GradientCss); border: 3px solid rgba(255,255,255,0.2);">
                        @initials.ToUpper()
                    </div>
                }
                <div class="upload-overlay">
                    <i class="bi bi-camera-fill text-white text-xl mb-1"></i>
                    <span class="text-white text-[10px] font-bold uppercase tracking-wider">Upload</span>
                </div>
            </div>

            <!-- Gender badge -->
            <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest"
                 style="background: @avatar.BgColor; border: 1px solid @avatar.BorderColor; color: @avatar.AccentHex;">
                <i class="bi @avatar.Icon"></i> @avatar.Label
            </div>

            <!-- Remove photo link -->
            @if (hasPhoto) {
                <form asp-action="RemovePhoto" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-[10px] text-white/30 hover:text-red-400 font-bold uppercase tracking-wider transition-colors bg-transparent border-none cursor-pointer">
                        <i class="bi bi-trash3 text-[9px]"></i> Remove
                    </button>
                </form>
            }
        </div>

        <!-- Hidden upload form -->
        <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" id="photoForm" class="hidden">
            @Html.AntiForgeryToken()
            <input type="file" name="photo" id="photoInput" accept=".jpg,.jpeg,.png,.webp"
                   onchange="document.getElementById('photoForm').submit();" class="hidden" />
        </form>

        <!-- Text -->
        <div class="relative p-6 sm:p-8 pr-32 sm:pr-52" style="z-index: 5;">
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-1">My Profile</h1>
            <div class="flex items-center gap-3 mt-1">
                <span class="px-3 py-1 rounded-full bg-blue-500/15 border border-blue-500/30 text-blue-400 text-xs font-mono font-bold">PT-@Model.Id.ToString("D4")</span>
                <span class="text-white/50 text-sm">@Model.FirstName @Model.LastName · @Model.Gender · @Model.Age yrs</span>
            </div>
            @if (TempData["ProfileSuccess"] != null) {
                <div class="mt-3 inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm font-bold">
                    <i class="bi bi-check2-circle"></i> @TempData["ProfileSuccess"]
                </div>
            }
            @if (TempData["ProfileError"] != null) {
                <div class="mt-3 inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-sm font-bold">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["ProfileError"]
                </div>
            }
        </div>
    </div>

    <div class="glass-panel p-8 md:p-10 rounded-[32px]">
        <form asp-controller="User" asp-action="UpdateProfile" method="post">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2"><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Patient ID</label><input type="text" value="PT-@Model.Id.ToString("D4")" class="custom-input !text-blue-400 !font-mono !font-bold cursor-not-allowed" readonly></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">First Name</label><input type="text" name="FirstName" value="@Model.FirstName" class="custom-input" required></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Last Name</label><input type="text" name="LastName" value="@Model.LastName" class="custom-input" required></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Age</label><input type="number" name="Age" value="@Model.Age" class="custom-input" required></div>
                <div>
                    <label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Gender</label>
                    <select name="Gender" class="custom-input">
                        <option value="Male" selected="@(Model.Gender == "Male")">Male</option>
                        <option value="Female" selected="@(Model.Gender == "Female")">Female</option>
                        <option value="Other" selected="@(Model.Gender == "Other")">Other</option>
                    </select>
                </div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Mobile (Read-only)</label><input type="text" value="@Model.Mobile" class="custom-input !text-white/30 cursor-not-allowed" readonly></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Email <span class="text-white/20 normal-case">(Optional)</span></label><input type="email" name="Email" value="@Model.Email" class="custom-input" placeholder="example@email.com"></div>
                
                <div class="md:col-span-2 border-t border-white/10 pt-6 mt-4">
                    <h4 class="text-white font-medium mb-4">Home Address for Collection</h4>
                </div>

                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Area / Place</label><input type="text" name="Place" value="@Model.Place" class="custom-input"></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">City</label><input type="text" name="City" value="@Model.City" class="custom-input" required></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">State</label><input type="text" name="State" value="@Model.State" class="custom-input"></div>
                <div><label class="block text-[11px] font-bold text-white/50 uppercase mb-2">Pincode</label><input type="text" name="Pincode" value="@Model.Pincode" class="custom-input" required></div>

                <div class="md:col-span-2 mt-6 flex items-center gap-4">
                    <button type="submit" class="btn-wrapper max-w-[240px]"><div class="btn-inner-cta py-[12px] w-full">Save Changes</div></button>
                    <a href="/User/ChangePassword" class="text-blue-400 text-sm font-bold no-underline hover:text-blue-300 transition-colors flex items-center gap-1">
                        <i class="bi bi-shield-lock"></i> Change Password
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>