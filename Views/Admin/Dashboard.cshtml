@model ksp.care.Helpers.PaginatedList<ksp.care.Models.AppointmentRecord>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<!-- Stats Row -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-5 mb-8">
    <div class="glass-panel rounded-2xl p-6 border border-white/10">
        <div class="flex items-center justify-between mb-3">
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider">Appointments</span>
            <i class="bi bi-calendar-check text-blue-500 text-lg"></i>
        </div>
        <div class="text-4xl font-bold text-white">@Model.Count</div>
    </div>
    <div class="glass-panel rounded-2xl p-6 border border-white/10">
        <div class="flex items-center justify-between mb-3">
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider">Pending</span>
            <i class="bi bi-hourglass-split text-yellow-500 text-lg"></i>
        </div>
        <div class="text-4xl font-bold text-yellow-400">@ViewBag.PendingCount</div>
    </div>
    <div class="glass-panel rounded-2xl p-6 border border-white/10">
        <div class="flex items-center justify-between mb-3">
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider">Patients</span>
            <i class="bi bi-people text-green-500 text-lg"></i>
        </div>
        <div class="text-4xl font-bold text-white">@ViewBag.TotalPatients</div>
    </div>
    <div class="glass-panel rounded-2xl p-6 border border-white/10">
        <div class="flex items-center justify-between mb-3">
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider">Doctors</span>
            <i class="bi bi-heart-pulse text-purple-500 text-lg"></i>
        </div>
        <div class="text-4xl font-bold text-purple-400">@ViewBag.TotalDoctors</div>
    </div>
    <div class="glass-panel rounded-2xl p-6 border border-white/10">
        <div class="flex items-center justify-between mb-3">
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider">Bill Due</span>
            <i class="bi bi-currency-rupee text-red-400 text-lg"></i>
        </div>
        <div class="text-3xl font-bold text-red-400">&#8377;@(((decimal)ViewBag.TotalBillDue).ToString("N0"))</div>
    </div>
</div>

<!-- Appointments Table -->
<div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
    <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
        <h2 class="text-xl font-bold text-white m-0">All Appointments</h2>
        <div class="flex items-center gap-3">
            <form method="get" class="flex items-center gap-2">
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Search name or mobile..."
                    class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 placeholder:text-white/30 w-64" />
                <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                    <a href="/Admin/Dashboard" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm rounded-lg transition-colors no-underline">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </form>
            <a asp-controller="Admin" asp-action="Report"
               class="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-full transition-colors no-underline">
                <i class="bi bi-upload"></i> Upload Report
            </a>
        </div>
    </div>

    @if (!Model.Any()) {
        <div class="p-16 text-center">
            <i class="bi bi-calendar-x text-5xl text-white/20 block mb-3"></i>
            <p class="text-white/40 font-medium">No appointments found.</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Booking ID</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Package</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Date & Time</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Sample ID</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Status</th>
                        <th class="px-4 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Update</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var appt in Model) {
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-4 py-4 font-mono text-purple-400 text-sm font-bold">BK-@appt.Id.ToString("D4")</td>
                            <td class="px-4 py-4">
                                <div class="text-white font-semibold text-sm">@appt.PatientName</div>
                                <div class="text-white/40 text-xs">@appt.PatientMobile</div>
                                @if (appt.DoctorId.HasValue) {
                                    var doc = ((List<ksp.care.Models.DoctorRecord>)ViewBag.Doctors).FirstOrDefault(d => d.Id == appt.DoctorId);
                                    if (doc != null) {
                                        <div class="text-blue-400/80 text-[10px] mt-0.5"><i class="bi bi-person-badge-fill"></i> Dr. @doc.Name</div>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(appt.PhlebotomistName)) {
                                    <div class="text-purple-400/80 text-[10px] mt-0.5"><i class="bi bi-droplet-fill"></i> @appt.PhlebotomistName</div>
                                }
                            </td>
                            <td class="px-4 py-4 text-white/80 text-sm">@appt.PackageName</td>
                            <td class="px-4 py-4">
                                <div class="text-white/80 text-sm">@appt.AppointmentDate.ToString("dd MMM yyyy")</div>
                                <div class="text-white/40 text-xs">@appt.AppointmentTime</div>
                            </td>
                            <td class="px-4 py-4">
                                @if (!string.IsNullOrEmpty(appt.SampleId)) {
                                    <span class="px-2 py-1 rounded-lg bg-teal-500/10 text-teal-400 text-[11px] font-mono font-bold">@appt.SampleId</span>
                                } else {
                                    <span class="text-white/20 text-xs">—</span>
                                }
                            </td>
                            <td class="px-4 py-4">
                                @{
                                    var badge = appt.Status switch {
                                        "Confirmed" => "bg-green-500/20 text-green-400 border-green-500/30",
                                        "Sample Collected" => "bg-teal-500/20 text-teal-400 border-teal-500/30",
                                        "Sample Received" => "bg-purple-500/20 text-purple-400 border-purple-500/30",
                                        "Report Ready" => "bg-blue-500/20 text-blue-400 border-blue-500/30",
                                        "Completed" => "bg-emerald-500/20 text-emerald-400 border-emerald-500/30",
                                        "Cancelled" => "bg-red-500/20 text-red-400 border-red-500/30",
                                        _ => "bg-yellow-500/20 text-yellow-400 border-yellow-500/30"
                                    };
                                }
                                <span class="px-3 py-1 rounded-full border text-[10px] font-bold @badge">@appt.Status</span>
                            </td>
                            <td class="px-4 py-4">
                                <div class="flex flex-col gap-2">
                                    <form asp-action="UpdateStatus" method="post" class="flex items-center gap-1.5">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        @{
                                            var statuses = new[] { "Pending", "Confirmed", "Sample Collected", "Sample Received", "Report Ready", "Completed", "Cancelled" };
                                        }
                                        <select name="newStatus" class="bg-white/5 border border-white/10 text-white text-[11px] rounded-lg px-2 py-1.5 outline-none">
                                            @foreach (var s in statuses) {
                                                @Html.Raw($"<option value=\"{s}\" {(appt.Status == s ? "selected" : "")}>{s}</option>")
                                            }
                                        </select>
                                        <button type="submit"
                                            class="px-2.5 py-1.5 bg-white/10 hover:bg-white/20 text-white text-[10px] font-bold rounded-lg transition-colors">
                                            Save
                                        </button>
                                    </form>

                                    <form asp-action="AssignDoctor" method="post" class="flex items-center gap-1.5">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appt.Id" />
                                            <select name="doctorId" required class="bg-white/5 border border-white/10 text-white text-[11px] rounded-lg px-2 py-1.5 outline-none w-[125px]">
                                                <option value="">@(appt.DoctorId.HasValue ? "Change Doctor..." : "Assign Doctor...")</option>
                                                @if (ViewBag.Doctors != null) {
                                                    foreach (var doc in (List<ksp.care.Models.DoctorRecord>)ViewBag.Doctors) {
                                                        @Html.Raw($"<option value=\"{doc.Id}\" {(appt.DoctorId == doc.Id ? "selected" : "")}>Dr. {doc.Name}</option>")
                                                    }
                                                }
                                            </select>
                                            <button type="submit"
                                                class="px-2.5 py-1.5 @(appt.DoctorId.HasValue ? "bg-purple-500/20 hover:bg-purple-500/40 text-purple-400" : "bg-blue-500/20 hover:bg-blue-500/40 text-blue-400") text-[10px] font-bold rounded-lg transition-colors">
                                                @(appt.DoctorId.HasValue ? "Change" : "Assign")
                                            </button>
                                        </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1) {
        <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
            @if (Model.HasPreviousPage) {
                <a href="/Admin/Dashboard?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            }
            <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
            @if (Model.HasNextPage) {
                <a href="/Admin/Dashboard?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
</div>
