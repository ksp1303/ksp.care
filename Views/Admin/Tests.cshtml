@model ksp.care.Helpers.PaginatedList<ksp.care.Models.TestRecord>
@{
    ViewData["Title"] = "Test Catalog";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<div class="grid lg:grid-cols-3 gap-8">
    <!-- Add Test Form -->
    <div class="glass-panel rounded-[24px] border border-white/10 p-8 h-fit">
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="bi bi-plus-circle text-blue-400"></i> Add Test
        </h2>
        <form asp-action="AddTest" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Test Name</label>
                <input type="text" name="testName" required
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-blue-500/50 placeholder:text-white/30"
                    placeholder="e.g. Complete Blood Count" />
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Category</label>
                <select name="category" required class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-blue-500/50">
                    <option value="Haematology" class="bg-black">Haematology</option>
                    <option value="Biochemistry" class="bg-black">Biochemistry</option>
                    <option value="Immunology" class="bg-black">Immunology</option>
                    <option value="Microbiology" class="bg-black">Microbiology</option>
                    <option value="Hormones" class="bg-black">Hormones</option>
                    <option value="Vitamins" class="bg-black">Vitamins</option>
                    <option value="Cardiac" class="bg-black">Cardiac</option>
                    <option value="Urine & Stool" class="bg-black">Urine & Stool</option>
                    <option value="Health Package" class="bg-black">Health Package</option>
                    <option value="Other" class="bg-black">Other</option>
                </select>
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Price (₹)</label>
                <input type="number" name="price" step="0.01" min="0" required
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-blue-500/50 placeholder:text-white/30"
                    placeholder="e.g. 350" />
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Description (Optional)</label>
                <textarea name="description" rows="2"
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-blue-500/50 placeholder:text-white/30 resize-none"
                    placeholder="Brief description of the test..."></textarea>
            </div>
            <button type="submit"
                class="w-full px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-colors">
                <i class="bi bi-plus-lg mr-2"></i> Add Test
            </button>
        </form>
    </div>

    <!-- Test List -->
    <div class="lg:col-span-2 glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
        <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
            <h2 class="text-xl font-bold text-white m-0">Test Catalog</h2>
            <form method="get" class="flex items-center gap-2">
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Search test or category..."
                    class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 placeholder:text-white/30 w-56" />
                <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                    <a href="/Admin/Tests" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm rounded-lg transition-colors no-underline">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </form>
        </div>

        @if (!Model.Any()) {
            <div class="p-16 text-center">
                <i class="bi bi-flask text-5xl text-white/20 block mb-3"></i>
                <p class="text-white/40 font-medium">No tests added yet.</p>
            </div>
        } else {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-white/10">
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">#</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Test Name</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Category</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Price</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Status</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var test in Model) {
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-5 py-4 font-mono text-white/50 text-sm">@test.Id</td>
                                <td class="px-5 py-4">
                                    <div class="text-white font-semibold text-sm">@test.TestName</div>
                                    @if (!string.IsNullOrEmpty(test.Description)) {
                                        <div class="text-white/30 text-xs mt-0.5">@test.Description</div>
                                    }
                                </td>
                                <td class="px-5 py-4">
                                    <span class="px-2.5 py-1 rounded-lg bg-blue-500/10 text-blue-400 text-xs font-bold">@test.Category</span>
                                </td>
                                <td class="px-5 py-4 text-white font-bold text-sm">&#8377;@test.Price.ToString("N2")</td>
                                <td class="px-5 py-4">
                                    @if (test.IsActive) {
                                        <span class="px-3 py-1 rounded-full border text-xs font-bold bg-green-500/20 text-green-400 border-green-500/30">Active</span>
                                    } else {
                                        <span class="px-3 py-1 rounded-full border text-xs font-bold bg-red-500/20 text-red-400 border-red-500/30">Inactive</span>
                                    }
                                </td>
                                <td class="px-5 py-4">
                                    <div class="flex items-center gap-2">
                                        <form asp-action="ToggleTestStatus" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@test.Id" />
                                            <button type="submit"
                                                class="px-3 py-1.5 text-xs font-bold rounded-lg transition-colors @(test.IsActive ? "bg-red-500/10 hover:bg-red-500/20 text-red-400" : "bg-green-500/10 hover:bg-green-500/20 text-green-400")">
                                                @(test.IsActive ? "Disable" : "Enable")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.TotalPages > 1) {
            <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
                @if (Model.HasPreviousPage) {
                    <a href="/Admin/Tests?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                       class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                }
                <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
                @if (Model.HasNextPage) {
                    <a href="/Admin/Tests?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                       class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        }
    </div>
</div>
