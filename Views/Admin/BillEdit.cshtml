@model ksp.care.Helpers.PaginatedList<ksp.care.Models.BillingRecord>
@{
    ViewData["Title"] = "Manage Bills";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-white mb-1 flex items-center gap-3">
            <i class="bi bi-pencil-square text-blue-400"></i> Bill Edit
        </h1>
        <p class="text-white/40 text-sm m-0">View, edit, delete and generate barcodes for bills.</p>
    </div>
    <a href="/Admin/PendingBill" class="flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 text-white font-bold text-sm rounded-xl transition-colors no-underline border border-white/10">
        <i class="bi bi-clock-history"></i> Pending Bills
    </a>
</div>

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
    <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
        <h2 class="text-xl font-bold text-white m-0">Bill Edit</h2>
        <form method="get" class="flex items-center gap-2">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Search by name or mobile..."
                class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 w-64" />
            <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>

    @if (!Model.Any()) {
        <div class="p-16 text-center">
            <i class="bi bi-receipt text-5xl text-white/20 block mb-3"></i>
            <p class="text-white/40 font-medium">No bills found.</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Bill Id</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient ID</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Booking ID</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient Name</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">MobileNumber</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider text-center">Edit</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider text-center">Delete</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider text-center">Generate BarCode</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var bill in Model) {
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-5 py-4 font-mono text-white/50 text-sm">@bill.Id</td>
                            <td class="px-5 py-4 font-mono text-blue-400 text-sm font-bold">@(bill.PatientId.HasValue ? $"PT-{bill.PatientId:D4}" : "—")</td>
                            <td class="px-5 py-4 font-mono text-purple-400 text-sm font-bold">@(bill.AppointmentId.HasValue ? $"BK-{bill.AppointmentId:D4}" : "—")</td>
                            <td class="px-5 py-4 text-white font-semibold text-sm">@bill.PatientName</td>
                            <td class="px-5 py-4 text-white/80 text-sm">@bill.PatientMobile</td>
                            <td class="px-5 py-4 text-center">
                                <a href="#" class="inline-flex w-8 h-8 rounded-lg border border-white/10 bg-white/5 items-center justify-center text-white/50 hover:text-blue-400 hover:border-blue-500/30 transition-colors" title="Edit (Coming Soon)">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            </td>
                            <td class="px-5 py-4 text-center">
                                <form asp-action="DeleteBill" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@bill.Id" />
                                    <button type="submit" class="inline-flex w-8 h-8 rounded-lg border border-white/10 bg-white/5 items-center justify-center text-white/50 hover:text-red-400 hover:border-red-500/30 transition-colors" onclick="return confirm('Are you sure you want to delete this bill?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="px-5 py-4 text-center">
                                <form asp-action="GenerateBarcode" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@bill.Id" />
                                    <button type="submit" class="px-4 py-1.5 bg-transparent border border-pink-500/50 hover:bg-pink-500/10 text-pink-400 text-xs font-bold rounded-lg transition-colors">
                                        BarCode
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.TotalPages > 1) {
        <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
            @if (Model.HasPreviousPage) {
                <a href="/Admin/BillEdit?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            }
            <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
            @if (Model.HasNextPage) {
                <a href="/Admin/BillEdit?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
</div>
