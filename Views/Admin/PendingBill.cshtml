@model ksp.care.Helpers.PaginatedList<ksp.care.Models.BillingRecord>
@{
    ViewData["Title"] = "Pending Bills";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var unbilledApts = ViewBag.UnbilledApts as List<ksp.care.Models.AppointmentRecord> ?? new List<ksp.care.Models.AppointmentRecord>();
}

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<!-- Total Due -->
<div class="glass-panel rounded-2xl p-6 border border-white/10 mb-8 inline-block">
    <div class="flex items-center gap-4">
        <i class="bi bi-currency-rupee text-red-400 text-3xl"></i>
        <div>
            <span class="text-white/50 text-[11px] font-bold uppercase tracking-wider block">Total Pending Amount</span>
            <span class="text-3xl font-bold text-red-400">&#8377;@(((decimal)ViewBag.TotalDue).ToString("N2"))</span>
        </div>
    </div>
</div>

<!-- Unbilled Confirmed Appointments -->
@if (unbilledApts.Any()) {
    <div class="glass-panel rounded-[24px] border border-yellow-500/20 bg-yellow-500/[0.02] overflow-hidden mb-8">
        <div class="px-6 py-5 border-b border-yellow-500/20">
            <h2 class="text-lg font-bold text-yellow-400 m-0 flex items-center gap-2">
                <i class="bi bi-exclamation-triangle"></i> Unbilled Confirmed Appointments
            </h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="px-5 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Ref #</th>
                        <th class="px-5 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient</th>
                        <th class="px-5 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Package</th>
                        <th class="px-5 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Amount & Bill</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var apt in unbilledApts) {
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-5 py-3 font-mono text-white/50 text-sm">#@apt.Id</td>
                            <td class="px-5 py-3">
                                <div class="text-white font-semibold text-sm">@apt.PatientName</div>
                                <div class="text-white/40 text-xs">@apt.PatientMobile</div>
                            </td>
                            <td class="px-5 py-3 text-white/80 text-sm">@apt.PackageName</td>
                            <td class="px-5 py-3">
                                <form asp-action="CreateBill" method="post" class="flex items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="appointmentId" value="@apt.Id" />
                                    <input type="number" name="amount" step="0.01" min="1" required placeholder="Amount"
                                        class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-3 py-2 outline-none focus:border-blue-500/50 w-28" />
                                    <button type="submit"
                                        class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-lg transition-colors"
                                        onclick="return confirm('Create bill for this appointment?')">
                                        Create Bill
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Pending Bills -->
<div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
    <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
        <h2 class="text-xl font-bold text-white m-0">Pending Bills</h2>
        <form method="get" class="flex items-center gap-2">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Search patient..."
                class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 placeholder:text-white/30 w-64" />
            <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                <a href="/Admin/PendingBill" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm rounded-lg transition-colors no-underline">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>

    @if (!Model.Any()) {
        <div class="p-16 text-center">
            <i class="bi bi-check-circle text-5xl text-green-500/30 block mb-3"></i>
            <p class="text-white/40 font-medium">No pending bills. All clear!</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Bill #</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient ID</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Booking ID</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Package</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Total</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Paid</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Pending</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Payment</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var bill in Model) {
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-5 py-4 font-mono text-white/50 text-sm">#@bill.Id</td>
                            <td class="px-5 py-4 font-mono text-blue-400 text-sm font-bold">@(bill.PatientId.HasValue ? $"PT-{bill.PatientId:D4}" : "—")</td>
                            <td class="px-5 py-4 font-mono text-purple-400 text-sm font-bold">@(bill.AppointmentId.HasValue ? $"BK-{bill.AppointmentId:D4}" : "—")</td>
                            <td class="px-5 py-4">
                                <div class="text-white font-semibold text-sm">@bill.PatientName</div>
                                <div class="text-white/40 text-xs">@bill.PatientMobile</div>
                            </td>
                            <td class="px-5 py-4 text-white/80 text-sm">@bill.PackageName</td>
                            <td class="px-5 py-4 text-white font-bold text-sm">&#8377;@bill.TotalAmount.ToString("N2")</td>
                            <td class="px-5 py-4 text-green-400 text-sm font-medium">&#8377;@bill.PaidAmount.ToString("N2")</td>
                            <td class="px-5 py-4 text-red-400 font-bold text-sm">&#8377;@bill.PendingAmount.ToString("N2")</td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-2">
                                    <form asp-action="RecordPayment" method="post" class="flex items-center gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@bill.Id" />
                                        <input type="number" name="amount" step="0.01" min="1" max="@bill.PendingAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" placeholder="₹ Amount"
                                            class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-3 py-1.5 outline-none focus:border-blue-500/50 w-24" />
                                        <button type="submit"
                                            class="px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-lg transition-colors">
                                            Pay
                                        </button>
                                    </form>
                                    <form asp-action="MarkAsPaid" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@bill.Id" />
                                        <button type="submit"
                                            class="px-4 py-1.5 bg-pink-600 hover:bg-pink-500 text-white text-xs font-bold rounded-lg shadow-[0_0_15px_rgba(219,39,119,0.3)] transition-all transform hover:scale-105"
                                            onclick="return confirm('Mark entire bill #@bill.Id as fully paid?')">
                                            PayNow
                                        </button>
                                    </form>
                                    <a href="/Admin/ViewInvoice?id=@bill.Id"
                                       class="px-3 py-1.5 bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 text-xs font-bold rounded-lg transition-colors no-underline"
                                       target="_blank">
                                        <i class="bi bi-receipt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.TotalPages > 1) {
        <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
            @if (Model.HasPreviousPage) {
                <a href="/Admin/PendingBill?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            }
            <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
            @if (Model.HasNextPage) {
                <a href="/Admin/PendingBill?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
</div>
