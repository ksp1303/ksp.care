@model IEnumerable<ksp.care.Models.AppointmentRecord>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "My Dashboard";
    var userName = ViewData["UserName"]?.ToString() ?? "Patient";
    var userPatientId = ViewData["UserPatientId"] is int pid ? pid : 0;
    var userGender = ViewData["UserGender"]?.ToString() ?? "Other";
    var userAge = ViewData["UserAge"] is int a ? a : 30;
    var avatar = ksp.care.Helpers.AvatarHelper.GetAvatar(userGender, userAge);
    var userPhoto = ViewData["UserPhoto"]?.ToString();
    var hasPhoto = !string.IsNullOrEmpty(userPhoto);

    var stages = new[] { "Pending", "Confirmed", "Sample Collected", "Sample Received", "Report Ready", "Completed" };
    var totalAppointments = Model.Count();
    var activeAppointments = Model.Count(m => m.Status != "Cancelled" && m.Status != "Completed");
    var completedAppointments = Model.Count(m => m.Status == "Completed");
}

<style>
    @@keyframes ringPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.1); }
        50% { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
    }
    @@keyframes glowPulse {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.08); }
    }
    .avatar-ring { animation: ringPulse 3s ease-in-out infinite; }
    .glow-pulse { animation: glowPulse 3s ease-in-out infinite; }
    .quick-action {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 20px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
    }
    .quick-action:hover {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.12);
        transform: translateY(-3px);
    }
    .quick-action:hover .qa-icon { transform: scale(1.1); }
    .qa-icon { transition: transform 0.3s; }
    .appt-card {
        padding: 24px;
        transition: background 0.2s;
    }
    .appt-card:hover { background: rgba(255,255,255,0.02); }
    .progress-step {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }
    .progress-bar {
        width: 100%;
        height: 6px;
        border-radius: 3px;
        transition: background 0.3s;
    }
</style>

<div class="max-w-[1100px] mx-auto">

    <!-- Welcome Banner with Initials Avatar -->
    <div class="mb-8 relative overflow-hidden rounded-[28px] border border-white/10"
         style="background: linear-gradient(135deg, @(avatar.BgColor), rgba(0,0,0,0.3)); min-height: 160px;">

        <!-- Glow -->
        <div class="absolute right-6 sm:right-16 top-1/2 -translate-y-1/2 w-36 h-36 sm:w-48 sm:h-48 rounded-full glow-pulse pointer-events-none"
             style="background: radial-gradient(circle, @(avatar.GlowColor), transparent 70%); z-index: 1;"></div>

        <!-- Avatar (photo or initials) -->
        <div class="absolute right-4 sm:right-10 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2" style="z-index: 5;">
            @if (hasPhoto) {
                <img src="@userPhoto" alt="@userName"
                     class="w-24 h-24 sm:w-32 sm:h-32 rounded-full object-cover shadow-2xl avatar-ring"
                     style="border: 3px solid rgba(255,255,255,0.25);" />
            } else {
                <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full flex items-center justify-center text-white font-bold text-4xl sm:text-5xl shadow-2xl avatar-ring"
                     style="background: @(avatar.GradientCss); border: 3px solid rgba(255,255,255,0.2);">
                    @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "?")
                </div>
            }
            <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest"
                 style="background: @avatar.BgColor; border: 1px solid @avatar.BorderColor; color: @avatar.AccentHex;">
                <i class="bi @avatar.Icon"></i> @avatar.Label
            </div>
        </div>

        <div class="relative p-6 sm:p-8 pr-32 sm:pr-56" style="z-index: 5;">
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-1">
                Welcome back, <span style="color: @avatar.AccentHex">@userName.Split(' ')[0]</span>
            </h1>
            <p class="text-white/50 text-sm mt-2">Here's your health activity summary.</p>
            <div class="flex items-center gap-4 mt-4">
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/15 border border-blue-500/30 text-blue-400 text-xs font-mono font-bold">
                    <i class="bi bi-person-badge"></i> PT-@userPatientId.ToString("D4")
                </div>                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-white/70 text-xs font-medium">
                    <i class="bi bi-calendar-check"></i> @totalAppointments total
                </div>
                @if (activeAppointments > 0) {
                    <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/15 text-blue-400 text-xs font-medium">
                        <div class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></div> @activeAppointments active
                    </div>
                }
            </div>
        </div>
    </div>

    @if (TempData["BookingSuccess"] != null) {
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/20 text-green-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-check-circle-fill"></i> @TempData["BookingSuccess"]
        </div>
    }
    @if (TempData["Error"] != null) {
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
        <a href="/User/Package" class="quick-action group">
            <div class="qa-icon w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-3">
                <i class="bi bi-calendar-plus text-blue-400"></i>
            </div>
            <h4 class="text-white font-semibold text-sm mb-1 group-hover:text-blue-400 transition-colors">Book a Package</h4>
            <p class="text-white/40 text-xs m-0">Schedule a home collection</p>
        </a>
        <a href="/User/Reports" class="quick-action group">
            <div class="qa-icon w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-3">
                <i class="bi bi-file-earmark-pdf text-green-400"></i>
            </div>
            <h4 class="text-white font-semibold text-sm mb-1 group-hover:text-green-400 transition-colors">My Reports</h4>
            <p class="text-white/40 text-xs m-0">View & download results</p>
        </a>
        <a href="/User/Bills" class="quick-action group">
            <div class="qa-icon w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-3">
                <i class="bi bi-receipt text-orange-400"></i>
            </div>
            <h4 class="text-white font-semibold text-sm mb-1 group-hover:text-orange-400 transition-colors">My Bills</h4>
            <p class="text-white/40 text-xs m-0">View billing & payments</p>
        </a>
        <a href="/User/Prescriptions" class="quick-action group">
            <div class="qa-icon w-10 h-10 rounded-xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center mb-3">
                <i class="bi bi-file-earmark-medical text-teal-400"></i>
            </div>
            <h4 class="text-white font-semibold text-sm mb-1 group-hover:text-teal-400 transition-colors">Prescriptions</h4>
            <p class="text-white/40 text-xs m-0">View doctor prescriptions</p>
        </a>
    </div>

    <!-- Appointments -->
    <div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
        <div class="flex items-center justify-between px-6 py-5 border-b border-white/10">
            <h3 class="text-lg font-bold text-white m-0 flex items-center gap-2">
                <i class="bi bi-calendar-event text-blue-500"></i> My Appointments
            </h3>
            <a href="/User/Package" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-lg transition-all no-underline flex items-center gap-1.5 shadow-[0_0_15px_rgba(59,130,246,0.2)]">
                <i class="bi bi-plus-lg"></i> New Booking
            </a>
        </div>

        @if (!Model.Any()) {
            <div class="p-12 text-center">
                <div class="w-16 h-16 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-calendar-x text-blue-400 text-3xl"></i>
                </div>
                <h4 class="text-white font-bold text-lg mb-2">No appointments yet</h4>
                <p class="text-white/40 text-sm mb-5">Book a health package to schedule your first home visit.</p>
                <a href="/User/Package" class="inline-flex items-center gap-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-full transition-all no-underline">
                    <i class="bi bi-calendar-plus"></i> Book Now
                </a>
            </div>
        } else {
            <div class="divide-y divide-white/5">
                @foreach (var appt in Model) {
                    var stageIndex = Array.IndexOf(stages, appt.Status);
                    var isCancelled = appt.Status == "Cancelled";

                    <div class="appt-card">
                        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-white font-bold text-sm">@appt.PackageName</span>
                                    <span class="px-2 py-0.5 rounded-md bg-purple-500/10 border border-purple-500/20 text-purple-400 text-[10px] font-mono font-bold">BK-@appt.Id.ToString("D4")</span>
                                </div>
                                <div class="text-white/40 text-xs mt-1 flex items-center gap-2">
                                    <i class="bi bi-calendar3 text-[10px]"></i> @appt.AppointmentDate.ToString("dd MMM yyyy")
                                    <span class="text-white/20">·</span>
                                    <i class="bi bi-clock text-[10px]"></i> @appt.AppointmentTime
                                </div>
                                @if (appt.DoctorId.HasValue) {
                                    var doc = ((List<ksp.care.Models.DoctorRecord>)ViewBag.Doctors).FirstOrDefault(d => d.Id == appt.DoctorId);
                                    if (doc != null) {
                                        <div class="mt-1.5 text-blue-400 text-xs font-medium flex items-center gap-1">
                                            <i class="bi bi-person-badge"></i> Dr. @doc.Name
                                        </div>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(appt.SampleId)) {
                                    <div class="mt-1.5">
                                        <span class="px-2.5 py-1 rounded-lg bg-teal-500/10 text-teal-400 text-[10px] font-mono font-bold border border-teal-500/20">@appt.SampleId</span>
                                    </div>
                                }
                            </div>
                            <div class="flex items-center gap-2">
                                @if (appt.Status == "Pending") {
                                    <form asp-action="CancelAppointment" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        <button type="submit"
                                            class="px-3 py-1.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-bold rounded-lg transition-colors border border-red-500/20"
                                            onclick="return confirm('Cancel this appointment?')">
                                            <i class="bi bi-x-circle me-1"></i> Cancel
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        @if (isCancelled) {
                            <div class="flex items-center gap-2 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
                                <i class="bi bi-x-circle text-red-400"></i>
                                <span class="text-red-400 text-sm font-bold">Cancelled</span>
                            </div>
                        } else {
                            <div class="flex items-center gap-1">
                                @for (int i = 0; i < stages.Length; i++) {
                                    var isCompleted = i <= stageIndex;
                                    var isCurrent = i == stageIndex;

                                    <div class="progress-step">
                                        <div class="progress-bar @(isCompleted ? "bg-blue-500" : "bg-white/10")"></div>
                                        <span class="text-[9px] font-bold @(isCurrent ? "text-blue-400" : isCompleted ? "text-white/50" : "text-white/20") text-center leading-tight">
                                            @stages[i]
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
