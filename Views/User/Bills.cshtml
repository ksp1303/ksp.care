@model IEnumerable<ksp.care.Models.BillingRecord>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "My Bills";
    var totalBilled = Model.Sum(b => b.TotalAmount);
    var totalPaid = Model.Sum(b => b.PaidAmount);
    var totalPending = Model.Sum(b => b.PendingAmount);
}

<style>
    .bill-stat-card {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 20px 24px;
        transition: all 0.3s;
    }
    .bill-stat-card:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.12);
    }
    .pay-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: rgba(0,0,0,0.80);
        backdrop-filter: blur(8px);
        opacity: 0;
        visibility: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        transition: all 0.3s ease;
    }
    .pay-modal-overlay.open { opacity: 1; visibility: visible; }
    .pay-modal-box {
        background: #0a0a0e;
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 20px;
        width: 100%;
        max-width: 440px;
        padding: 32px;
        position: relative;
        transform: scale(0.95);
        transition: transform 0.3s;
        box-shadow: 0 25px 60px rgba(0,0,0,0.6);
    }
    .pay-modal-overlay.open .pay-modal-box { transform: scale(1); }
</style>

<div class="max-w-[1100px] mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-white flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center">
                <i class="bi bi-receipt text-orange-400"></i>
            </div>
            My Bills
        </h1>
        <p class="text-white/50 text-sm mt-2 ml-[52px]">View your billing history and make payments.</p>
    </div>

    @if (TempData["Success"] != null) {
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/20 text-green-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null) {
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    <!-- Summary Cards -->
    @if (Model.Any()) {
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="bill-stat-card">
                <div class="text-white/35 text-[11px] font-bold uppercase tracking-wider mb-1">Total Billed</div>
                <div class="text-white text-2xl font-bold">&#8377;@totalBilled.ToString("N2")</div>
            </div>
            <div class="bill-stat-card">
                <div class="text-green-400/50 text-[11px] font-bold uppercase tracking-wider mb-1">Total Paid</div>
                <div class="text-green-400 text-2xl font-bold">&#8377;@totalPaid.ToString("N2")</div>
            </div>
            <div class="bill-stat-card">
                <div class="text-red-400/50 text-[11px] font-bold uppercase tracking-wider mb-1">Outstanding</div>
                <div class="text-red-400 text-2xl font-bold">&#8377;@totalPending.ToString("N2")</div>
            </div>
        </div>
    }

    <!-- Bills Table -->
    <div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
        @if (!Model.Any()) {
            <div class="p-16 text-center">
                <div class="w-16 h-16 rounded-2xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-receipt text-orange-400 text-3xl"></i>
                </div>
                <h3 class="text-white font-bold text-lg mb-2">No bills found</h3>
                <p class="text-white/40 text-sm mb-0">Your billing history will appear here once tests are booked.</p>
            </div>
        } else {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-white/10">
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Bill #</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient ID</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Package</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Total</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Paid</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Pending</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Date</th>
                            <th class="px-6 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var bill in Model) {
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4 font-mono text-white/50 text-sm">#@bill.Id</td>
                                <td class="px-6 py-4 font-mono text-blue-400 text-sm font-bold">@(bill.PatientId.HasValue ? $"PT-{bill.PatientId:D4}" : "—")</td>
                                <td class="px-6 py-4 text-white font-medium text-sm">@bill.PackageName</td>
                                <td class="px-6 py-4 text-white font-bold text-sm">&#8377;@bill.TotalAmount.ToString("N2")</td>
                                <td class="px-6 py-4 text-green-400 text-sm">&#8377;@bill.PaidAmount.ToString("N2")</td>
                                <td class="px-6 py-4 text-sm font-bold @(bill.PendingAmount > 0 ? "text-red-400" : "text-green-400")">
                                    &#8377;@bill.PendingAmount.ToString("N2")
                                </td>
                                <td class="px-6 py-4">
                                    @{
                                        var badge = bill.Status == "Paid"
                                            ? "bg-green-500/20 text-green-400 border-green-500/30"
                                            : "bg-yellow-500/20 text-yellow-400 border-yellow-500/30";
                                    }
                                    <span class="px-3 py-1 rounded-full border text-xs font-bold @badge">@bill.Status</span>
                                </td>
                                <td class="px-6 py-4 text-white/50 text-sm">@bill.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        @if (bill.Status == "Paid") {
                                            <a href="/User/ViewInvoice?id=@bill.Id" class="px-3 py-1.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 text-xs font-bold rounded-lg transition-colors no-underline" target="_blank">
                                                <i class="bi bi-download me-1"></i> Invoice
                                            </a>
                                        } else if (bill.PendingAmount > 0) {
                                            <button type="button"
                                                class="px-4 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-lg transition-all transform hover:scale-105 shadow-[0_0_15px_rgba(59,130,246,0.3)]"
                                                onclick="openPayModal(@bill.Id, '@bill.PackageName', @bill.PendingAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))">
                                                <i class="bi bi-credit-card me-1"></i> Pay Now
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ═══ Payment Modal ═══ -->
<div class="pay-modal-overlay" id="payModal">
    <div class="pay-modal-box">
        <button onclick="closePayModal()" class="absolute top-5 right-5 text-white/40 hover:text-white transition-colors" aria-label="Close">
            <i class="bi bi-x-lg text-xl"></i>
        </button>

        <div class="mb-6">
            <div class="w-14 h-14 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-4">
                <i class="bi bi-credit-card-2-front text-blue-400 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-1">Make Payment</h3>
            <p class="text-white/40 text-sm" id="payModalDesc"></p>
        </div>

        <form asp-controller="User" asp-action="PayBill" method="post" id="payForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="payBillId" />

            <div class="mb-4">
                <label class="text-white/40 text-[11px] font-bold uppercase tracking-wider mb-2 block">Outstanding Amount</label>
                <div class="text-2xl font-bold text-red-400" id="payOutstanding"></div>
            </div>

            <div class="mb-6">
                <label class="text-white/40 text-[11px] font-bold uppercase tracking-wider mb-2 block">Payment Amount (₹)</label>
                <input type="number" name="amount" id="payAmountInput" step="0.01" min="1" class="custom-input text-lg font-bold" placeholder="Enter amount" required />
            </div>

            <div class="flex items-center gap-3 mb-6">
                <button type="button" class="flex-1 py-2 text-xs font-bold rounded-lg bg-white/5 border border-white/10 text-white/60 hover:bg-white/10 transition-all" onclick="setPayAmount(0.25)">25%</button>
                <button type="button" class="flex-1 py-2 text-xs font-bold rounded-lg bg-white/5 border border-white/10 text-white/60 hover:bg-white/10 transition-all" onclick="setPayAmount(0.5)">50%</button>
                <button type="button" class="flex-1 py-2 text-xs font-bold rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400 hover:bg-blue-500/20 transition-all" onclick="setPayAmount(1)">Full</button>
            </div>

            <button type="submit"
                class="w-full py-3.5 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-all shadow-[0_0_20px_rgba(59,130,246,0.3)] flex items-center justify-center gap-2">
                <i class="bi bi-check-circle"></i> Confirm Payment
            </button>
        </form>

        <p class="text-white/20 text-[10px] text-center mt-4">Payment will be recorded immediately in your billing record.</p>
    </div>
</div>

<script>
    let currentOutstanding = 0;
    const payModal = document.getElementById('payModal');

    function openPayModal(billId, packageName, outstanding) {
        document.getElementById('payBillId').value = billId;
        document.getElementById('payModalDesc').textContent = `Bill #${billId} — ${packageName}`;
        document.getElementById('payOutstanding').textContent = `₹${outstanding.toFixed(2)}`;
        document.getElementById('payAmountInput').value = outstanding.toFixed(2);
        document.getElementById('payAmountInput').max = outstanding;
        currentOutstanding = outstanding;
        payModal.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closePayModal() {
        payModal.classList.remove('open');
        document.body.style.overflow = '';
    }

    function setPayAmount(fraction) {
        const amount = (currentOutstanding * fraction).toFixed(2);
        document.getElementById('payAmountInput').value = amount;
    }

    payModal.addEventListener('click', function(e) { if (e.target === payModal) closePayModal(); });
</script>
