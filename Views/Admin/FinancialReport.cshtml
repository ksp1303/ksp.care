@model IEnumerable<ksp.care.Models.BillingRecord>
@{
    ViewData["Title"] = "Financial Report";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-white mb-1 flex items-center gap-3">
        <i class="bi bi-bar-chart-line text-green-400"></i> Financial Report
    </h1>
    <p class="text-white/40 text-sm m-0">Filter billing records by date range and payment mode.</p>
</div>

<div class="glass-panel p-6 rounded-[24px] border border-white/10 bg-white/[0.02] mb-8">
    <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="space-y-2">
            <label class="text-[11px] font-bold text-white/50 uppercase tracking-wider">From Date</label>
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="w-full bg-[#0a0a0a] border border-white/10 text-white rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 [color-scheme:dark]" />
        </div>
        <div class="space-y-2">
            <label class="text-[11px] font-bold text-white/50 uppercase tracking-wider">To Date</label>
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="w-full bg-[#0a0a0a] border border-white/10 text-white rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 [color-scheme:dark]" />
        </div>
        <div class="space-y-2">
            @{
                var pmCash = ViewBag.PaymentMode?.ToString() == "Cash";
                var pmCard = ViewBag.PaymentMode?.ToString() == "Card";
                var pmUpi  = ViewBag.PaymentMode?.ToString() == "UPI";
            }
            <label class="text-[11px] font-bold text-white/50 uppercase tracking-wider">Payment Mode</label>
            <select name="paymentMode" class="w-full bg-[#0a0a0a] border border-white/10 text-white rounded-lg px-4 py-2 outline-none focus:border-blue-500/50">
                <option value="">All Modes</option>
                <option value="Cash" selected="@pmCash">Cash</option>
                <option value="Card" selected="@pmCard">Card</option>
                <option value="UPI"  selected="@pmUpi">UPI</option>
            </select>
        </div>
        <div class="flex items-end">
            <button type="submit" class="w-full md:w-auto px-6 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-lg transition-colors flex items-center gap-2">
                <i class="bi bi-funnel"></i> Apply Filter
            </button>
        </div>
    </form>
</div>

<div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-white/10 bg-white/5">
                    <th class="px-5 py-4 text-white font-bold text-sm">Patient ID</th>
                    <th class="px-5 py-4 text-white font-bold text-sm">Patient Name</th>
                    <th class="px-5 py-4 text-white font-bold text-sm">Payment Type</th>
                    <th class="px-5 py-4 text-white font-bold text-sm text-right">Amount</th>
                    <th class="px-5 py-4 text-white font-bold text-sm text-right">Discount(%)</th>
                    <th class="px-5 py-4 text-white font-bold text-sm text-right">Paid</th>
                    <th class="px-5 py-4 text-white font-bold text-sm text-right">Due</th>
                    <th class="px-5 py-4 text-white font-bold text-sm text-right">Net Amount</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @foreach(var bill in Model) {
                    <tr class="hover:bg-white/[0.02] transition-colors">
                        <td class="px-5 py-3 font-mono text-blue-400 text-sm font-bold">@(bill.PatientId.HasValue ? $"PT-{bill.PatientId:D4}" : "—")</td>
                        <td class="px-5 py-3 text-white/80 text-sm">@bill.PatientName</td>
                        <td class="px-5 py-3 text-white/80 text-sm">@(ViewBag.PaymentMode ?? "Mixed")</td>
                        <td class="px-5 py-3 text-white/80 text-sm text-right">@bill.TotalAmount.ToString("N2")</td>
                        <td class="px-5 py-3 text-white/80 text-sm text-right">0</td>
                        <td class="px-5 py-3 text-white/80 text-sm text-right">@bill.PaidAmount.ToString("N2")</td>
                        <td class="px-5 py-3 text-white/80 text-sm text-right">@bill.PendingAmount.ToString("N2")</td>
                        <td class="px-5 py-3 text-white/80 text-sm text-right font-bold">@bill.TotalAmount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="border-t-2 border-white/20">
                    <td colspan="3" class="px-5 py-4 text-white font-bold">Total</td>
                    <td class="px-5 py-4 text-white font-bold text-right">@(((decimal)ViewBag.GrandTotal).ToString("N2"))</td>
                    <td class="px-5 py-4 text-white font-bold text-right">0</td>
                    <td class="px-5 py-4 text-white font-bold text-right">@(((decimal)ViewBag.GrandPaid).ToString("N2"))</td>
                    <td class="px-5 py-4 text-white font-bold text-right">@(((decimal)ViewBag.GrandDue).ToString("N2"))</td>
                    <td class="px-5 py-4 text-white font-bold text-right">@(((decimal)ViewBag.GrandTotal).ToString("N2"))</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
