@{ 
    ViewData["Title"] = "Upload Lab Report"; 
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-[700px] mx-auto">
    <div class="mb-8 border-b border-white/10 pb-6">
        <h2 class="text-3xl font-bold text-white mb-1">Attach Patient Report</h2>
        <p class="text-white/50 text-sm m-0">Upload a PDF lab result to a patient's secure portal.</p>
    </div>

    @if (TempData["Error"] != null) {
        <div class="p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl mb-6 text-sm font-medium">@TempData["Error"]</div>
    }

    <div class="glass-panel p-8 rounded-[24px] border border-white/10 bg-white/[0.02]">
        <form asp-controller="Admin" asp-action="ProcessUpload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="mb-6">
                <label class="block text-white/50 text-[11px] font-bold uppercase mb-2">Select Patient</label>
                <select name="patientMobile" class="w-full bg-black/50 border border-white/10 text-white rounded-xl py-3 px-4 outline-none focus:border-blue-500" required>
                    <option value="">-- Choose Patient --</option>
                    @if(ViewBag.Patients != null) {
                        foreach(var p in ViewBag.Patients)
                        {
                            <option value="@p.Mobile">@p.FirstName @p.LastName (@p.Mobile)</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-6">
                <label class="block text-white/50 text-[11px] font-bold uppercase mb-2">Test / Package Name</label>
                <input type="text" name="testName" placeholder="e.g. Complete Blood Count" class="w-full bg-black/50 border border-white/10 text-white rounded-xl py-3 px-4 outline-none focus:border-blue-500" required>
            </div>

            <div class="mb-8">
                <label class="block text-white/50 text-[11px] font-bold uppercase mb-2">Upload PDF Document</label>
                <input type="file" name="reportFile" accept=".pdf" class="w-full bg-white/5 border border-white/10 text-white/70 rounded-xl py-3 px-4 outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-500/20 file:text-blue-400 hover:file:bg-blue-500/30" required>
            </div>

            <button type="submit" class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-colors shadow-lg shadow-blue-500/20">
                Upload & Publish to Patient Portal
            </button>
        </form>
    </div>
</div>