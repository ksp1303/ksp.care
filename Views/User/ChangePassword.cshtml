@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Change Password";
}

<style>
    .pwd-card {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        position: relative;
        overflow: hidden;
    }
    .pwd-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 20%;
        right: 20%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent);
    }
    .pwd-strength { height: 4px; border-radius: 2px; transition: all 0.3s; }
</style>

<div class="max-w-[500px] mx-auto">
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                <i class="bi bi-shield-lock text-blue-400"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-white m-0">Change Password</h1>
                <p class="text-white/40 text-sm m-0">Update your account password for security.</p>
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null) {
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }
    @if (TempData["ProfileSuccess"] != null) {
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm flex items-center gap-2 auto-dismiss">
            <i class="bi bi-check-circle-fill"></i> @TempData["ProfileSuccess"]
        </div>
    }

    <div class="pwd-card p-8">
        <form asp-action="UpdatePassword" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div>
                <label class="text-white/50 text-[11px] font-bold uppercase tracking-wider mb-2 block">Current Password</label>
                <div class="relative">
                    <input type="password" name="currentPassword" required id="currentPwd"
                        class="custom-input !pr-10" placeholder="Enter current password" />
                    <button type="button" onclick="togglePwd('currentPwd', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/60 transition-colors">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>
            <div>
                <label class="text-white/50 text-[11px] font-bold uppercase tracking-wider mb-2 block">New Password</label>
                <div class="relative">
                    <input type="password" name="newPassword" required minlength="8" id="newPwd"
                        oninput="checkStrength(this.value)"
                        class="custom-input !pr-10" placeholder="Enter new password (min 8 chars)" />
                    <button type="button" onclick="togglePwd('newPwd', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/60 transition-colors">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <div class="flex gap-1 mt-2">
                    <div id="str1" class="pwd-strength flex-1 bg-white/10"></div>
                    <div id="str2" class="pwd-strength flex-1 bg-white/10"></div>
                    <div id="str3" class="pwd-strength flex-1 bg-white/10"></div>
                    <div id="str4" class="pwd-strength flex-1 bg-white/10"></div>
                </div>
                <div id="strLabel" class="text-[10px] font-bold uppercase tracking-wider mt-1.5 text-white/30"></div>
            </div>
            <div>
                <label class="text-white/50 text-[11px] font-bold uppercase tracking-wider mb-2 block">Confirm New Password</label>
                <div class="relative">
                    <input type="password" name="confirmPassword" required minlength="8" id="confirmPwd"
                        class="custom-input !pr-10" placeholder="Confirm new password" />
                    <button type="button" onclick="togglePwd('confirmPwd', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/60 transition-colors">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>
            <button type="submit"
                class="w-full py-3.5 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-all shadow-[0_0_20px_rgba(59,130,246,0.3)] flex items-center justify-center gap-2">
                <i class="bi bi-check-lg"></i> Update Password
            </button>
        </form>
    </div>

    <div class="mt-6 text-center">
        <a href="/User/Profile" class="text-white/40 text-sm hover:text-white/60 transition-colors inline-flex items-center gap-1.5 no-underline">
            <i class="bi bi-arrow-left text-xs"></i> Back to Profile
        </a>
    </div>
</div>

<script>
    function togglePwd(id, btn) {
        var inp = document.getElementById(id);
        var icon = btn.querySelector('i');
        if (inp.type === 'password') {
            inp.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            inp.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    function checkStrength(pwd) {
        var score = 0;
        if (pwd.length >= 4) score++;
        if (pwd.length >= 8) score++;
        if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
        if (/[0-9]/.test(pwd) && /[^a-zA-Z0-9]/.test(pwd)) score++;

        var colors = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-green-500'];
        var labels = ['Weak', 'Fair', 'Good', 'Strong'];
        var labelColors = ['text-red-400', 'text-orange-400', 'text-yellow-400', 'text-green-400'];

        for (var i = 1; i <= 4; i++) {
            var el = document.getElementById('str' + i);
            el.className = 'pwd-strength flex-1 ' + (i <= score ? colors[score - 1] : 'bg-white/10');
        }
        var lbl = document.getElementById('strLabel');
        if (pwd.length === 0) {
            lbl.textContent = '';
            lbl.className = 'text-[10px] font-bold uppercase tracking-wider mt-1.5 text-white/30';
        } else {
            lbl.textContent = labels[score - 1] || 'Too short';
            lbl.className = 'text-[10px] font-bold uppercase tracking-wider mt-1.5 ' + (labelColors[score - 1] || 'text-red-400');
        }
    }
</script>
