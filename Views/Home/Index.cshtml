@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";

    // Package prices come from the DB (Admin → Tests) so the homepage always
    // matches what patients are billed; hardcoded values are only a fallback.
    var dbPackages = ViewBag.Packages as List<ksp.care.Models.TestRecord>;
    string PkgPrice(string name, decimal fallback)
    {
        var price = dbPackages?.FirstOrDefault(p => p.TestName == name)?.Price ?? fallback;
        return "₹" + price.ToString("N0");
    }
}

<style>
    /* ── Hero Background ─────────────────────────────────────── */
    .hero-section {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .hero-bg-video {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
            radial-gradient(ellipse 60% 50% at 20% 20%, rgba(59,130,246,0.18), transparent 60%),
            radial-gradient(ellipse 50% 40% at 80% 60%, rgba(139,92,246,0.12), transparent 60%),
            #030305;
    }
    .hero-bg-video video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .hero-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg,
            rgba(3,3,5,0.3) 0%,
            rgba(3,3,5,0.5) 40%,
            rgba(3,3,5,0.85) 70%,
            rgba(3,3,5,1) 100%
        );
        z-index: 1;
    }

    /* ── Floating Orbs ───────────────────────────────────────── */
    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.4;
        z-index: 0;
        pointer-events: none;
    }
    .orb-1 {
        width: 400px;
        height: 400px;
        background: rgba(59, 130, 246, 0.15);
        top: 10%;
        left: -5%;
        animation: float 8s ease-in-out infinite;
    }
    .orb-2 {
        width: 300px;
        height: 300px;
        background: rgba(139, 92, 246, 0.1);
        top: 30%;
        right: -5%;
        animation: float 10s ease-in-out infinite reverse;
    }

    /* ── Hero Nav ─────────────────────────────────────────────── */
    .hero-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        background: rgba(3,3,5,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        transition: all 0.3s ease;
    }
    .hero-nav.scrolled {
        background: rgba(3,3,5,0.95);
