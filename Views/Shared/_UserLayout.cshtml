<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")kspcare Portal</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tailwind.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body { font-family: 'General Sans', sans-serif; background-color: #050505; color: white; min-height: 100vh; overflow-x: hidden; }
        .glass-panel { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); }
        .custom-input { background-color: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(255, 255, 255, 0.1) !important; color: white !important; border-radius: 12px !important; padding: 14px 16px !important; width: 100%; outline: none; transition: border-color 0.2s; }
        .custom-input:focus { border-color: rgba(59,130,246,0.6) !important; }
        .custom-input::placeholder { color: rgba(255,255,255,0.3); }
        select.custom-input option { background-color: #0a0a0c; color: white; }
        .btn-wrapper { position: relative; display: inline-flex; border-radius: 9999px; padding: 0.6px; background: rgba(255,255,255,0.4); overflow: hidden; cursor: pointer; text-decoration: none; transition: transform 0.2s; }
        .btn-wrapper:hover { transform: translateY(-2px); }
        .btn-inner-cta { background-color: #ffffff; color: #000000; border-radius: 9999px; padding: 10px 24px; font-weight: 600; text-align: center; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }

        /* Mobile menu */
        .user-mobile-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.6);
            z-index: 199; opacity: 0; visibility: hidden; transition: all 0.3s;
        }
        .user-mobile-overlay.open { opacity: 1; visibility: visible; }
        .user-mobile-menu {
            position: fixed; top: 0; right: -100%; width: 280px; height: 100vh;
            background: #0a0a0e; border-left: 1px solid rgba(255,255,255,0.06);
            z-index: 200; transition: right 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            padding: 80px 24px 32px;
        }
        .user-mobile-menu.open { right: 0; }
        .user-mobile-link {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px; border-radius: 12px;
            font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.6);
            text-decoration: none; transition: all 0.15s;
        }
        .user-mobile-link:hover { background: rgba(255,255,255,0.05); color: white; }
        .user-mobile-link.active { color: white; background: rgba(255,255,255,0.05); }
    </style>
</head>
<body class="bg-[#050505]">

    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    }

    <nav class="w-full flex items-center justify-between px-6 md:px-12 py-4 border-b border-white/10 bg-black/80 backdrop-blur-md sticky top-0 z-50">
        <div class="flex items-center gap-8">
            <a href="/User/Dashboard" class="flex items-center gap-2 no-underline">
                <i class="bi bi-droplet-fill text-blue-500 text-2xl"></i>
                <span class="text-xl font-bold text-white lowercase">ksp<span class="text-blue-500">care</span></span>
            </a>
            <div class="hidden md:flex gap-6">
                <a href="/User/Dashboard" class="text-sm font-medium @(currentAction == "Dashboard" ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">Dashboard</a>
                <a href="/User/Package"   class="text-sm font-medium @(currentAction == "Package"   ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">Book Package</a>
                <a href="/User/Reports"   class="text-sm font-medium @(currentAction == "Reports"   ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">My Reports</a>
                <a href="/User/Bills"      class="text-sm font-medium @(currentAction == "Bills"     ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">My Bills</a>
                <a href="/User/Prescriptions" class="text-sm font-medium @(currentAction == "Prescriptions" ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">Prescriptions</a>
                <a href="/User/Profile"   class="text-sm font-medium @(currentAction == "Profile"   ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors">Profile</a>
                <a href="/User/ChangePassword" class="text-sm font-medium @(currentAction == "ChangePassword" ? "text-white" : "text-white/60 hover:text-white") no-underline transition-colors"><i class="bi bi-shield-lock"></i></a>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <!-- FIX: calls User/Logout which does Session.Clear() -->
            <a asp-controller="User" asp-action="Logout"
               class="text-white/50 hover:text-red-400 text-xl no-underline transition-colors hidden md:block" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
            <!-- Mobile hamburger -->
            <button id="userMobileBtn" class="md:hidden w-10 h-10 flex items-center justify-center text-white/60 hover:text-white transition-colors" aria-label="Open menu">
                <i class="bi bi-list text-2xl"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="user-mobile-overlay" id="userMobileOverlay"></div>
    <div class="user-mobile-menu" id="userMobileMenu">
        <button id="userMobileClose" class="absolute top-6 right-6 text-white/50 hover:text-white text-2xl transition-colors" aria-label="Close menu">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="flex flex-col gap-1">
            <a href="/User/Dashboard" class="user-mobile-link @(currentAction == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2 text-lg"></i> Dashboard
            </a>
            <a href="/User/Package" class="user-mobile-link @(currentAction == "Package" ? "active" : "")">
                <i class="bi bi-calendar-plus text-lg"></i> Book Package
            </a>
            <a href="/User/Reports" class="user-mobile-link @(currentAction == "Reports" ? "active" : "")">
                <i class="bi bi-file-earmark-pdf text-lg"></i> My Reports
            </a>
            <a href="/User/Bills" class="user-mobile-link @(currentAction == "Bills" ? "active" : "")">
                <i class="bi bi-receipt text-lg"></i> My Bills
            </a>
            <a href="/User/Prescriptions" class="user-mobile-link @(currentAction == "Prescriptions" ? "active" : "")">
                <i class="bi bi-file-earmark-medical text-lg"></i> Prescriptions
            </a>
            <a href="/User/Profile" class="user-mobile-link @(currentAction == "Profile" ? "active" : "")">
                <i class="bi bi-person text-lg"></i> Profile
            </a>
            <a href="/User/ChangePassword" class="user-mobile-link @(currentAction == "ChangePassword" ? "active" : "")">
                <i class="bi bi-shield-lock text-lg"></i> Change Password
            </a>
            <hr class="border-white/10 my-3" />
            <a asp-controller="User" asp-action="Logout" class="user-mobile-link text-red-400/70 hover:text-red-400">
                <i class="bi bi-box-arrow-right text-lg"></i> Logout
            </a>
        </div>
    </div>

    <main class="container mx-auto px-6 py-10 max-w-[1200px]">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/[0.06] mt-auto">
        <div class="max-w-[1200px] mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <i class="bi bi-droplet-fill text-blue-500 text-sm"></i>
                <span class="text-sm font-bold text-white/30 lowercase">ksp<span class="text-blue-500/50">care</span></span>
                <span class="text-white/15 text-xs ml-2">&copy; 2026 All rights reserved.</span>
            </div>
            <div class="flex items-center gap-6">
                <a href="/Home/Privacy" class="text-white/25 hover:text-white/50 text-xs font-medium transition-colors no-underline">Privacy</a>
                <a href="/Home/Contact" class="text-white/25 hover:text-white/50 text-xs font-medium transition-colors no-underline">Support</a>
                <a href="/" class="text-white/25 hover:text-white/50 text-xs font-medium transition-colors no-underline">Home</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js"></script>
    <script>
        // Mobile menu toggle
        (function() {
            var btn = document.getElementById('userMobileBtn');
            var closeBtn = document.getElementById('userMobileClose');
            var menu = document.getElementById('userMobileMenu');
            var overlay = document.getElementById('userMobileOverlay');

            function openMenu() {
                menu.classList.add('open');
                overlay.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
            function closeMenu() {
                menu.classList.remove('open');
                overlay.classList.remove('open');
                document.body.style.overflow = '';
            }
            if (btn) btn.addEventListener('click', openMenu);
            if (closeBtn) closeBtn.addEventListener('click', closeMenu);
            if (overlay) overlay.addEventListener('click', closeMenu);
        })();
    </script>
</body>
</html>
