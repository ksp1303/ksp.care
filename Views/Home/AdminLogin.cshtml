@{
    ViewData["Title"] = "Staff Terminal Access";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .staff-login-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #030305;
        overflow: hidden;
    }
    .staff-bg-grid {
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml;base64,");
        opacity: 0.5;
    }
    .staff-bg-gradient {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at top right, rgba(59,130,246,0.06) 0%, transparent 60%),
                    radial-gradient(ellipse at bottom left, rgba(139,92,246,0.04) 0%, transparent 60%);
    }
    .staff-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 460px;
        margin: 0 16px;
        padding: 40px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    }
    .staff-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 20%;
        right: 20%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent);
    }
    .staff-input {
        background-color: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.06) !important;
        color: white !important;
        border-radius: 14px !important;
        padding: 14px 16px 14px 46px !important;
        width: 100% !important;
        outline: none !important;
        font-size: 14px;
        transition: all 0.25s ease !important;
    }
    .staff-input:focus {
        border-color: rgba(59,130,246,0.5) !important;
        background-color: rgba(255,255,255,0.06) !important;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.1) !important;
    }
    .staff-input::placeholder { color: rgba(255,255,255,0.25); }
    .staff-icon {
        position: absolute;
        left: 16px;
        bottom: 15px;
        color: rgba(255,255,255,0.30);
        font-size: 18px;
        z-index: 10;
        pointer-events: none;
    }
    .staff-btn {
        width: 100%;
        padding: 14px 24px;
        background: #3b82f6;
        color: white;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 14px;
        border: none;
        transition: all 0.25s ease;
        box-shadow: 0 0 20px rgba(59,130,246,0.25);
    }
    .staff-btn:hover {
        background: #2563eb;
        box-shadow: 0 0 30px rgba(59,130,246,0.4);
        transform: translateY(-2px);
    }
    .status-badge {
        position: absolute;
        top: 24px;
        right: 24px;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 100px;
        background: rgba(16,185,129,0.08);
        border: 1px solid rgba(16,185,129,0.15);
    }
</style>

<div class="staff-login-page">
    <div class="staff-bg-grid"></div>
    <div class="staff-bg-gradient"></div>

    <div class="staff-card anim-fade-up">
        <!-- Status Badge -->
        <div class="status-badge">
            <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
            <span class="text-[10px] font-bold text-green-400 uppercase tracking-widest">System Online</span>
        </div>

        <!-- Header -->
        <div class="text-center mb-8 mt-2">
            <div class="w-16 h-16 mx-auto bg-blue-500/10 border border-blue-500/20 rounded-2xl flex items-center justify-center mb-5 shadow-[0_0_30px_rgba(59,130,246,0.1)]">
                <i class="bi bi-shield-lock-fill text-blue-500 text-3xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-white mb-2">Staff Terminal</h2>
            <p class="text-white/40 text-sm">Authenticate to access patient records & lab data.</p>
        </div>

        @if (TempData["Error"] != null) {
            <div class="mb-6 p-3.5 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-center text-sm font-bold">
                <i class="bi bi-exclamation-triangle mr-1"></i> @TempData["Error"]
            </div>
        }

        <form asp-controller="Home" asp-action="ProcessAdminLogin" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-5 relative">
                <label class="block text-[11px] font-bold text-white/40 uppercase tracking-wider mb-2">Staff ID Number</label>
                <i class="bi bi-person-badge staff-icon"></i>
                <input type="text" name="staffId" class="staff-input" placeholder="e.g. KSP-001" required>
            </div>

            <div class="mb-8 relative">
                <label class="block text-[11px] font-bold text-white/40 uppercase tracking-wider mb-2">Secure Passkey</label>
                <i class="bi bi-key staff-icon"></i>
                <input type="password" name="passkey" class="staff-input" placeholder="Enter access code" required>
            </div>

            <button type="submit" class="staff-btn">
                <i class="bi bi-shield-check mr-1"></i> Authenticate
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-white/[0.06]">
            <a href="/" class="text-white/30 hover:text-white/60 text-sm font-medium no-underline transition-colors">
                <i class="bi bi-arrow-left mr-1"></i> Return to Public Site
            </a>
        </div>
    </div>
</div>