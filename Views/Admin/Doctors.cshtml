@model IEnumerable<ksp.care.Models.DoctorRecord>
@{
    ViewData["Title"] = "Doctors";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null) {
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<div class="grid lg:grid-cols-3 gap-8">
    <!-- Add Doctor Form -->
    <div class="glass-panel rounded-[24px] border border-white/10 p-8 h-fit">
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="bi bi-person-plus text-purple-400"></i> Add Doctor
        </h2>
        <form asp-action="AddDoctor" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Full Name</label>
                <input type="text" name="name" required
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-purple-500/50 placeholder:text-white/30"
                    placeholder="Dr. Name" />
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Specialization</label>
                <input type="text" name="specialization" required
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-purple-500/50 placeholder:text-white/30"
                    placeholder="e.g. General Physician" />
            </div>
            <div>
                <label class="text-white/50 text-xs font-bold uppercase tracking-wider mb-2 block">Mobile (Optional)</label>
                <input type="tel" name="mobile"
                    class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-4 py-3 outline-none focus:border-purple-500/50 placeholder:text-white/30"
                    placeholder="Phone number" />
            </div>
            <button type="submit"
                class="w-full px-6 py-3 bg-purple-600 hover:bg-purple-500 text-white font-bold text-sm rounded-xl transition-colors">
                <i class="bi bi-plus-lg mr-2"></i> Add Doctor
            </button>
        </form>
    </div>

    <!-- Doctor List -->
    <div class="lg:col-span-2 glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
        <div class="px-6 py-5 border-b border-white/10">
            <h2 class="text-xl font-bold text-white m-0">All Doctors</h2>
        </div>

        @if (!Model.Any()) {
            <div class="p-16 text-center">
                <i class="bi bi-heart-pulse text-5xl text-white/20 block mb-3"></i>
                <p class="text-white/40 font-medium mb-4">No doctors added yet.</p>
                <a href="/Admin/SeedDoctors" class="inline-flex items-center gap-2 px-5 py-2.5 bg-purple-600 hover:bg-purple-500 text-white text-sm font-bold rounded-xl transition-colors no-underline">
                    <i class="bi bi-magic"></i> Seed 8 Sample Doctors
                </a>
            </div>
        } else {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-white/10">
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">#</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Name</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Specialization</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Mobile</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Status</th>
                            <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var doc in Model) {
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-5 py-4 font-mono text-white/50 text-sm">@doc.Id</td>
                                <td class="px-5 py-4 text-white font-semibold text-sm">@doc.Name</td>
                                <td class="px-5 py-4 text-white/70 text-sm">@doc.Specialization</td>
                                <td class="px-5 py-4 text-white/60 text-sm font-mono">@(string.IsNullOrEmpty(doc.Mobile) ? "—" : doc.Mobile)</td>
                                <td class="px-5 py-4">
                                    @if (doc.IsActive) {
                                        <span class="px-3 py-1 rounded-full border text-xs font-bold bg-green-500/20 text-green-400 border-green-500/30">Active</span>
                                    } else {
                                        <span class="px-3 py-1 rounded-full border text-xs font-bold bg-red-500/20 text-red-400 border-red-500/30">Inactive</span>
                                    }
                                </td>
                                <td class="px-5 py-4">
                                    <form asp-action="ToggleDoctorStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <button type="submit"
                                            class="px-3 py-1.5 text-xs font-bold rounded-lg transition-colors @(doc.IsActive ? "bg-red-500/10 hover:bg-red-500/20 text-red-400" : "bg-green-500/10 hover:bg-green-500/20 text-green-400")"
                                            onclick="return confirm('Are you sure you want to @(doc.IsActive ? "deactivate" : "activate") Dr. @doc.Name?')">
                                            @(doc.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
