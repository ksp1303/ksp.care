@model IEnumerable<ksp.care.Models.ReportRecord>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "My Reports";
}

<style>
    .report-card {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        padding: 24px;
        transition: all 0.3s ease;
    }
    .report-card:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.12);
        transform: translateY(-3px);
    }
    .report-card:hover .report-icon { transform: scale(1.1); }
    .report-icon { transition: transform 0.3s; }
</style>

<div class="max-w-[1100px] mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-white flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center">
                <i class="bi bi-file-earmark-pdf text-green-400"></i>
            </div>
            My Lab Reports
        </h1>
        <p class="text-white/50 text-sm mt-2 ml-[52px]">View and download your official pathology results.</p>
    </div>

    @{
        var pendingTests = ViewBag.PendingTests as List<ksp.care.Models.AppointmentRecord> ?? new List<ksp.care.Models.AppointmentRecord>();
    }

    @if (pendingTests.Any()) {
        <div class="mb-8 glass-panel rounded-[24px] border border-yellow-500/20 bg-yellow-500/[0.02] overflow-hidden">
            <div class="px-6 py-4 border-b border-yellow-500/15 bg-yellow-500/5 flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-yellow-500/15 flex items-center justify-center">
                    <i class="bi bi-hourglass-split text-yellow-400"></i>
                </div>
                <h3 class="text-base font-bold text-yellow-400 m-0">Pending Tests — Awaiting Results</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-white/5">
                            <th class="px-6 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Test/Package</th>
                            <th class="px-6 py-3 text-white/40 text-[11px] font-bold uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var test in pendingTests) {
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-3 text-white/60 text-sm">@test.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="px-6 py-3 text-white font-medium text-sm">@test.PackageName</td>
                                <td class="px-6 py-3">
                                    <span class="px-3 py-1 rounded-full border text-[10px] font-bold bg-yellow-500/10 text-yellow-400 border-yellow-500/20 flex items-center gap-1.5 w-fit">
                                        <div class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></div> Processing
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Model == null || !Model.Any()) {
        <div class="glass-panel rounded-[24px] border border-white/10 p-12 text-center">
            <div class="w-16 h-16 rounded-2xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-file-earmark-x text-green-400 text-3xl"></i>
            </div>
            <h3 class="text-white font-bold text-lg mb-2">No Reports Available</h3>
            <p class="text-white/40 text-sm mb-0">Your reports will appear here once the lab uploads them.</p>
        </div>
    } else {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach(var report in Model)
            {
                <div class="report-card">
                    <div class="flex items-start justify-between mb-5">
                        <div class="report-icon w-12 h-12 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 flex items-center justify-center text-xl shadow-[0_0_15px_rgba(239,68,68,0.15)]">
                            <i class="bi bi-file-earmark-pdf-fill"></i>
                        </div>
                        <span class="text-white/30 text-[10px] font-bold uppercase tracking-wider">@report.UploadedAt.ToString("dd MMM yyyy")</span>
                    </div>
                    <h4 class="text-white font-bold text-lg mb-1 truncate" title="@report.TestName">@report.TestName</h4>
                    <p class="text-white/40 text-xs mb-5">Generated by kspcare Lab</p>

                    <a href="@report.FilePath" target="_blank" download
                       class="block w-full py-2.5 text-center bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-all no-underline shadow-[0_0_15px_rgba(59,130,246,0.2)] flex items-center justify-center gap-2">
                        <i class="bi bi-download"></i> Download PDF
                    </a>
                </div>
            }
        </div>
    }
</div>