@{
    var doctors = ViewBag.Doctors as List<ksp.care.Models.DoctorRecord>;
    var doctorGradients = new[] {
        "linear-gradient(135deg, #3b82f6, #1d4ed8)",
        "linear-gradient(135deg, #8b5cf6, #6d28d9)",
        "linear-gradient(135deg, #10b981, #047857)",
        "linear-gradient(135deg, #f59e0b, #b45309)",
        "linear-gradient(135deg, #ec4899, #be185d)",
        "linear-gradient(135deg, #14b8a6, #0f766e)",
        "linear-gradient(135deg, #ef4444, #b91c1c)",
        "linear-gradient(135deg, #6366f1, #4338ca)"
    };
}
@if (doctors != null && doctors.Count > 0)
{
<section id="doctors" class="relative py-24 md:py-32 bg-[#030305] border-t border-white/[0.04]">
    <div class="max-w-[1100px] mx-auto px-6">
        <div class="text-center mb-16">
            <div class="section-tag"><i class="bi bi-person-badge"></i> Our Experts</div>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Meet Our Doctors</h2>
            <p class="text-white/45 max-w-[550px] mx-auto text-[15px] leading-relaxed">
                A dedicated panel of specialists reviewing every report behind the scenes.
            </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            @for (var i = 0; i < doctors.Count; i++)
            {
                var doc = doctors[i];
                var parts = doc.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                var docInitials = string.Concat(parts.Take(2).Select(p => p[0])).ToUpper();
                <div class="feature-card text-center !p-6">
                    <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-white font-bold text-xl shadow-lg"
                         style="background: @doctorGradients[i % doctorGradients.Length];">
                        @docInitials
                    </div>
                    <h4 class="text-white font-bold text-base mb-1">Dr. @doc.Name</h4>
                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-wider m-0">@doc.Specialization</p>
                </div>
            }
        </div>
    </div>
</section>
}

