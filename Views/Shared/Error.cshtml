@model ksp.care.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-black flex items-center justify-center px-6">
    <div class="text-center max-w-[500px]">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-center justify-center">
            <i class="bi bi-exclamation-triangle-fill text-red-400 text-4xl"></i>
        </div>
        <h1 class="text-4xl font-bold text-white mb-2">Something went wrong</h1>
        <p class="text-white/50 mb-6">An error occurred while processing your request.</p>

        @if (Model?.ShowRequestId == true)
        {
            <div class="mb-6 p-4 rounded-xl bg-white/5 border border-white/10 text-left">
                <p class="text-white/50 text-xs font-bold uppercase mb-1">Request ID</p>
                <code class="text-white/80 text-sm font-mono">@Model.RequestId</code>
            </div>
        }

        <a href="/Home/Index"
           class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-bold rounded-full hover:bg-white/90 transition-colors no-underline">
            <i class="bi bi-arrow-left"></i> Return to Home
        </a>
    </div>
</div>
