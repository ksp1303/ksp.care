@model ksp.care.Helpers.PaginatedList<ksp.care.Models.PatientRecord>
@{
    ViewData["Title"] = "Patients";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-white mb-1">Patient Records</h1>
        <p class="text-white/40 text-sm m-0">Manage and view all registered patients.</p>
    </div>
    <a href="/Admin/RegisterPatient" class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-colors no-underline shadow-lg shadow-blue-500/20">
        <i class="bi bi-person-plus-fill"></i> Register New Patient
    </a>
</div>

@if (TempData["Success"] != null) {
    <div class="mb-4 p-4 bg-green-500/10 border border-green-500/30 text-green-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null) {
    <div class="mb-4 p-4 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl text-sm font-medium flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<div class="glass-panel rounded-[24px] border border-white/10 bg-white/[0.02] overflow-hidden">
    <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5 border-b border-white/10">
        <h2 class="text-base font-bold text-white/70 m-0">All Patients</h2>
        <form method="get" class="flex items-center gap-2">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Search name or mobile..."
                class="bg-white/5 border border-white/10 text-white text-sm rounded-lg px-4 py-2 outline-none focus:border-blue-500/50 placeholder:text-white/30 w-64" />
            <button type="submit" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                <a href="/Admin/Patient" class="px-3 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm rounded-lg transition-colors no-underline">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>

    @if (!Model.Any()) {
        <div class="p-16 text-center">
            <i class="bi bi-people text-5xl text-white/20 block mb-3"></i>
            <p class="text-white/40 font-medium">No patients found.</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10">
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Patient ID</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Name</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Mobile</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Age</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Gender</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">City</th>
                        <th class="px-5 py-4 text-white/40 text-[11px] font-bold uppercase tracking-wider">Ward</th>
                        <th class="px-5 py-4 text-right text-white/40 text-[11px] font-bold uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var p in Model) {
                        var av = ksp.care.Helpers.AvatarHelper.GetAvatar(p.Gender, p.Age);
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="px-5 py-4 font-mono text-blue-400 text-sm font-bold">PT-@p.Id.ToString("D4")</td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg"
                                         style="background: @av.BgColor; border: 1.5px solid @av.BorderColor; box-shadow: 0 0 0 0 @av.GlowColor;">
                                        <i class="bi @av.Icon text-base" style="color: @av.AccentHex;"></i>
                                    </div>
                                    <div>
                                        <span class="text-white font-semibold text-sm block">@p.FirstName @p.LastName</span>
                                        <span class="text-[10px] font-bold uppercase tracking-widest" style="color: @av.AccentHex; opacity: 0.7;">@av.Label</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4 text-white/80 text-sm font-mono">@p.Mobile</td>
                            <td class="px-5 py-4 text-white/70 text-sm">@p.Age</td>
                            <td class="px-5 py-4 text-white/70 text-sm">@p.Gender</td>
                            <td class="px-5 py-4 text-white/70 text-sm">@p.City</td>
                            <td class="px-5 py-4 text-white/70 text-sm">@(p.Ward ?? "—")</td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Admin/EditPatient/@p.Id" class="px-3 py-1.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 text-xs font-bold rounded-lg transition-colors no-underline">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="/Admin/DeletePatient" onsubmit="return confirm('Are you sure you want to delete @p.FirstName? This will permanently delete their account.');" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="submit" class="px-3 py-1.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-bold rounded-lg transition-colors">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.TotalPages > 1) {
        <div class="flex items-center justify-center gap-3 px-6 py-5 border-t border-white/10">
            @if (Model.HasPreviousPage) {
                <a href="/Admin/Patient?page=@(Model.PageIndex - 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            }
            <span class="text-white/40 text-sm">Page @Model.PageIndex of @Model.TotalPages</span>
            @if (Model.HasNextPage) {
                <a href="/Admin/Patient?page=@(Model.PageIndex + 1)&search=@ViewBag.Search"
                   class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors no-underline">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
</div>