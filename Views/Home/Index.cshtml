<!-- ═══ Package Detail Modal ═══ -->
<div id="packageModal" class="modal-overlay">
    <div class="modal-box" id="modalContent">
        <button onclick="closePackageModal()" class="absolute top-5 right-5 text-white/40 hover:text-white transition-colors" aria-label="Close modal">
            <i class="bi bi-x-lg text-xl"></i>
        </button>

        <div class="mb-6 pb-4 border-b border-white/10 pr-8">
            <h4 id="modalTitle" class="text-2xl font-bold text-white mb-2"></h4>
            <p id="modalDesc" class="text-white/45 text-sm m-0"></p>
            <div id="modalPrice" class="text-blue-400 font-bold text-xl mt-3"></div>
        </div>

        <div id="modalTestList" class="space-y-3 mb-8 max-h-[40vh] overflow-y-auto pr-2"></div>

        <a href="/Home/UserLogin" class="btn-primary w-full py-4 text-center block">
            <i class="bi bi-box-arrow-in-right"></i> Login to Schedule
        </a>
    </div>
</div>

<script>
    // ── Package Modal ─────────────────────────────────────────
    const packageData = {
        'basic': {
            title: 'Basic Master Health',
            price: '@Html.Raw(PkgPrice("Basic Master Health", 1499m))',
            desc: 'A comprehensive panel of 40+ routine tests to evaluate your overall health status.',
            tests: ['Complete Blood Count (CBC)', 'Fasting Blood Sugar (FBS)', 'Lipid Profile', 'Liver Function Test (LFT)', 'Kidney Function Test (KFT)', 'Urine Routine Examination']
        },
        'comprehensive': {
            title: 'Comprehensive Body',
            price: '@Html.Raw(PkgPrice("Comprehensive Body", 2999m))',
            desc: 'Our most detailed screening covering 60+ parameters including hormones and advanced markers.',
            tests: ['All tests in Basic Master Health', 'Thyroid Profile (T3, T4, TSH)', 'HbA1c (3-month blood sugar average)', 'Iron Profile', 'Vitamin D (25-OH)', 'Vitamin B12']
        },
        'vitamin': {
            title: 'Vitamin Profile',
            price: '@Html.Raw(PkgPrice("Vitamin Profile", 999m))',
            desc: 'Targeted assessment of essential vitamins and bone health markers.',
            tests: ['Vitamin D (25-OH)', 'Vitamin B12', 'Serum Calcium', 'Folate (Vitamin B9)']
        },
        'cardiac': {
            title: 'Cardiac Care',
            price: '@Html.Raw(PkgPrice("Cardiac Care", 1799m))',
            desc: 'Specific markers designed to evaluate heart health and cardiovascular risk factors.',
            tests: ['Complete Lipid Profile', 'hs-CRP (Inflammation marker)', 'Homocysteine', 'Fasting Blood Sugar (FBS)', 'HbA1c']
        },
        'diabetes': {
            title: 'Diabetes Screening',
            price: '@Html.Raw(PkgPrice("Diabetes Screening", 1299m))',
            desc: 'Comprehensive screening to detect, monitor, and manage diabetes with key metabolic markers.',
            tests: ['Fasting Blood Sugar (FBS)', 'Post Prandial Blood Sugar (PPBS)', 'HbA1c (Glycated Hemoglobin)', 'Fasting Insulin', 'HOMA-IR (Insulin Resistance)', 'Kidney Function Test (KFT)', 'Urine Microalbumin', 'Lipid Profile']
        },
        'thyroid': {
            title: 'Thyroid Panel',
            price: '@Html.Raw(PkgPrice("Thyroid Panel", 899m))',
            desc: 'Complete thyroid function assessment for hypo/hyperthyroidism screening and monitoring.',
            tests: ['T3 (Triiodothyronine)', 'T4 (Thyroxine)', 'TSH (Thyroid Stimulating Hormone)', 'Free T3', 'Free T4', 'Anti-TPO Antibodies', 'Anti-Thyroglobulin Antibodies']
        },
        'liver_kidney': {
            title: 'Liver & Kidney Panel',
            price: '@Html.Raw(PkgPrice("Liver & Kidney Panel", 1599m))',
            desc: 'Detailed evaluation of liver and kidney function with essential organ health markers.',
            tests: ['Liver Function Test (LFT) — SGOT, SGPT, ALP, Bilirubin, Albumin, Protein', 'Kidney Function Test (KFT) — Creatinine, BUN, Uric Acid', 'Electrolytes (Na, K, Cl)', 'GGT (Gamma-Glutamyl Transferase)', 'Urine Routine & Microscopy', 'eGFR (Estimated Glomerular Filtration Rate)']
        },
        'womens': {
            title: "Women's Health",
            price: '@Html.Raw(PkgPrice("Women's Health", 2499m))',
            desc: 'Tailored screening package for women covering hormonal, nutritional, and metabolic health.',
            tests: ['Complete Blood Count (CBC)', 'Iron Profile & Ferritin', 'Thyroid Profile (T3, T4, TSH)', 'Vitamin D (25-OH)', 'Vitamin B12', 'Calcium & Phosphorus', 'FSH & LH (Reproductive Hormones)', 'Prolactin', 'Lipid Profile', 'Fasting Blood Sugar']
        }
    };

    const modal = document.getElementById('packageModal');
    const modalContent = document.getElementById('modalContent');

    function openPackageModal(key) {
        const data = packageData[key];
        if (!data) return;
        document.getElementById('modalTitle').textContent = data.title;
        document.getElementById('modalDesc').textContent = data.desc;
        document.getElementById('modalPrice').textContent = data.price || '';
        const list = document.getElementById('modalTestList');
        list.innerHTML = '';
        data.tests.forEach(t => {
            list.innerHTML += `<div class="flex items-start gap-3 text-white/70 text-sm"><i class="bi bi-check-circle-fill text-blue-500 mt-[2px] flex-shrink-0"></i><span>${t}</span></div>`;
        });
        modal.classList.add('modal-show');
        document.body.style.overflow = 'hidden';
    }

    function closePackageModal() {
        modal.classList.remove('modal-show');
        document.body.style.overflow = '';
    }

    modal.addEventListener('click', function(e) { if (e.target === modal) closePackageModal(); });

    // ── Navbar scroll ─────────────────────────────────────────
    const heroNav = document.getElementById('heroNav');
    if (heroNav) {
        window.addEventListener('scroll', function() {
            heroNav.classList.toggle('scrolled', window.scrollY > 60);
        });
    }

    // ── Mobile menu (homepage) ────────────────────────────────
    const heroMobileBtn = document.getElementById('heroMobileBtn');
    const heroMobileClose = document.getElementById('heroMobileClose');
    const heroMobileMenu = document.getElementById('heroMobileMenu');
    const heroMobileOverlay = document.getElementById('heroMobileOverlay');

    function openMobileHome() {
        heroMobileMenu.classList.add('open');
        heroMobileOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeMobileHome() {
        heroMobileMenu.classList.remove('open');
        heroMobileOverlay.classList.remove('open');
        document.body.style.overflow = '';
    }
    if (heroMobileBtn) heroMobileBtn.addEventListener('click', openMobileHome);
    if (heroMobileClose) heroMobileClose.addEventListener('click', closeMobileHome);
    if (heroMobileOverlay) heroMobileOverlay.addEventListener('click', closeMobileHome);

    // ── Hero video: respect reduced motion & data saver ───────
    const heroVideo = document.getElementById('heroVideo');
    if (heroVideo) {
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const saveData = navigator.connection && navigator.connection.saveData;
        if (reducedMotion || saveData) {
            heroVideo.pause();
            heroVideo.removeAttribute('autoplay');
        }
    }
</script>