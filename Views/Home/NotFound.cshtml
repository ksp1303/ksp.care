@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-black flex items-center justify-center px-6">
    <div class="text-center max-w-[500px]">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
            <i class="bi bi-compass text-blue-400 text-4xl"></i>
        </div>
        <p class="text-blue-400 font-bold text-sm uppercase tracking-[0.2em] mb-3">404</p>
        <h1 class="text-4xl font-bold text-white mb-2">Page not found</h1>
        <p class="text-white/50 mb-8">The page you're looking for doesn't exist or may have been moved.</p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/"
               class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-bold rounded-full hover:bg-white/90 transition-colors no-underline">
                <i class="bi bi-house"></i> Return to Home
            </a>
            <a href="/Home/Contact"
               class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 font-bold rounded-full hover:text-white hover:border-white/40 transition-colors no-underline">
                <i class="bi bi-headset"></i> Contact Support
            </a>
        </div>
    </div>
</div>
